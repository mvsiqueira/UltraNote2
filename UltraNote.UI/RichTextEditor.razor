@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IUltraNoteApi Api

@*
  TipTap-based rich-text editor (ported from the original Tauri/React UltraNotes app).
  Self-contained: owns its own toolbar, color palettes, and right-click context menu
  (including table operations). The JS side lives in editor-src/ (built with esbuild into
  wwwroot/ultranote-editor.js — see editor-src/package.json).
*@

<div class="rte" @onclick="CloseColorMenus">
    <div class="rte-toolbar">
        <button type="button" title="Negrito" @onclick='() => Exec("bold")'><i class="ti ti-bold" aria-hidden="true"></i></button>
        <button type="button" title="Itálico" @onclick='() => Exec("italic")'><i class="ti ti-italic" aria-hidden="true"></i></button>
        <button type="button" title="Tachado" @onclick='() => Exec("strike")'><i class="ti ti-strikethrough" aria-hidden="true"></i></button>
        <span class="rte-sep"></span>

        <div class="color-swatch">
            <button type="button" class="color-swatch-btn" title="Cor da fonte"
                    @onclick:stopPropagation="true" @onclick='() => ToggleColorMenu("font")'>
                <span class="font-indicator" style="color:@_fontColor">A</span>
            </button>
            @if (_activeColorMenu == "font")
            {
                <div class="color-palette" @onclick:stopPropagation="true">
                    @if (_recentFontColors.Count > 0)
                    {
                        <span class="palette-label">Recentes</span>
                        <div class="palette-row">
                            @foreach (var c in _recentFontColors)
                            {
                                <button type="button" class="swatch" style="background:@c" title="@c" @onclick="() => PickFontColor(c)"></button>
                            }
                        </div>
                    }
                    <span class="palette-label">Cores</span>
                    <div class="palette-grid">
                        @foreach (var c in PaletteColors)
                        {
                            <button type="button" class="swatch" style="background:@c" title="@c" @onclick="() => PickFontColor(c)"></button>
                        }
                    </div>
                    <div class="palette-custom">
                        <input type="color" value="@_fontColor" title="Cor personalizada"
                               @onchange="(e) => PickFontColor(e.Value?.ToString() ?? _fontColor)" />
                        <span>Personalizada</span>
                    </div>
                </div>
            }
        </div>

        <div class="color-swatch">
            <button type="button" class="color-swatch-btn" title="Cor de realce"
                    @onclick:stopPropagation="true" @onclick='() => ToggleColorMenu("highlight")'>
                <span class="highlight-indicator" style="background:@_highlightColor">A</span>
            </button>
            @if (_activeColorMenu == "highlight")
            {
                <div class="color-palette" @onclick:stopPropagation="true">
                    @if (_recentHighlightColors.Count > 0)
                    {
                        <span class="palette-label">Recentes</span>
                        <div class="palette-row">
                            @foreach (var c in _recentHighlightColors)
                            {
                                <button type="button" class="swatch" style="background:@c" title="@c" @onclick="() => PickHighlight(c)"></button>
                            }
                        </div>
                    }
                    <span class="palette-label">Cores</span>
                    <div class="palette-grid">
                        @foreach (var c in PaletteColors)
                        {
                            <button type="button" class="swatch" style="background:@c" title="@c" @onclick="() => PickHighlight(c)"></button>
                        }
                    </div>
                    <div class="palette-custom">
                        <input type="color" value="@_highlightColor" title="Cor personalizada"
                               @onchange="(e) => PickHighlight(e.Value?.ToString() ?? _highlightColor)" />
                        <span>Personalizada</span>
                    </div>
                </div>
            }
        </div>

        <span class="rte-sep"></span>
        <button type="button" title="Lista" @onclick='() => Exec("bulletList")'><i class="ti ti-list" aria-hidden="true"></i></button>
        <button type="button" title="Lista numerada" @onclick='() => Exec("orderedList")'><i class="ti ti-list-numbers" aria-hidden="true"></i></button>
        <button type="button" title="Reduzir recuo" @onclick='() => Exec("outdent")'><i class="ti ti-indent-decrease" aria-hidden="true"></i></button>
        <button type="button" title="Aumentar recuo" @onclick='() => Exec("indent")'><i class="ti ti-indent-increase" aria-hidden="true"></i></button>
        <span class="rte-sep"></span>
        <button type="button" title="Link" @onclick="InsertLink"><i class="ti ti-link" aria-hidden="true"></i></button>
        <button type="button" title="Tabela" @onclick='() => Exec("insertTable")'><i class="ti ti-table" aria-hidden="true"></i></button>
        <button type="button" title="Inserir imagem" @onclick="InsertImageFromFile" disabled="@(NoteId is null)"><i class="ti ti-photo" aria-hidden="true"></i></button>
        <span class="rte-sep"></span>
        <button type="button" title="Remover formatação" @onclick='() => Exec("clearFormatting")'><i class="ti ti-clear-formatting" aria-hidden="true"></i></button>
    </div>

    <div @ref="_surface" class="rte-surface"></div>
</div>

@if (_ctxMenu is not null)
{
    <div class="menu-backdrop" @onclick="CloseCtxMenu" @oncontextmenu:preventDefault="true" @oncontextmenu="CloseCtxMenu"></div>
    <div class="menu" style="left:@($"{_ctxMenu.X}px");top:@($"{_ctxMenu.Y}px")">
        @if (_ctxMenu.InImage)
        {
            <button @onclick="DetachImage"><i class="ti ti-paperclip" aria-hidden="true"></i>Transformar em anexo</button>
            <button class="danger" @onclick="DeleteImage"><i class="ti ti-photo-x" aria-hidden="true"></i>Excluir imagem</button>
        }
        else
        {
            <button @onclick='() => RunCtx("bold")'><i class="ti ti-bold" aria-hidden="true"></i>Negrito</button>
            <button @onclick='() => RunCtx("italic")'><i class="ti ti-italic" aria-hidden="true"></i>Itálico</button>
            <button @onclick='() => RunCtx("strike")'><i class="ti ti-strikethrough" aria-hidden="true"></i>Tachado</button>
            <button @onclick="OpenCtxFontColor"><i class="ti ti-letter-case" aria-hidden="true"></i>Fonte</button>
            @if (_ctxColorMode == "font")
            {
                <div class="ctx-color-panel">
                    <div class="palette-grid">
                        @foreach (var c in PaletteColors)
                        {
                            <button type="button" class="swatch" style="background:@c" title="@c" @onclick="() => PickCtxFontColor(c)"></button>
                        }
                    </div>
                    <div class="palette-custom">
                        <input type="color" value="@_fontColor" title="Cor personalizada"
                               @onchange="(e) => PickCtxFontColor(e.Value?.ToString() ?? _fontColor)" />
                        <span>Personalizada</span>
                    </div>
                </div>
            }
            <button @onclick="OpenCtxHighlight"><i class="ti ti-highlight" aria-hidden="true"></i>Realce</button>
            @if (_ctxColorMode == "highlight")
            {
                <div class="ctx-color-panel">
                    <div class="palette-grid">
                        @foreach (var c in PaletteColors)
                        {
                            <button type="button" class="swatch" style="background:@c" title="@c" @onclick="() => PickCtxHighlight(c)"></button>
                        }
                    </div>
                    <div class="palette-custom">
                        <input type="color" value="@_highlightColor" title="Cor personalizada"
                               @onchange="(e) => PickCtxHighlight(e.Value?.ToString() ?? _highlightColor)" />
                        <span>Personalizada</span>
                    </div>
                </div>
            }
            <hr />
            <button @onclick='() => RunCtx("bulletList")'><i class="ti ti-list" aria-hidden="true"></i>Lista</button>
            <button @onclick='() => RunCtx("orderedList")'><i class="ti ti-list-numbers" aria-hidden="true"></i>Lista numerada</button>

            @if (_ctxMenu.InTable)
            {
                <hr />
                <button @onclick='() => RunCtx("addColumnBefore")'><i class="ti ti-column-insert-left" aria-hidden="true"></i>Inserir coluna antes</button>
                <button @onclick='() => RunCtx("addColumnAfter")'><i class="ti ti-column-insert-right" aria-hidden="true"></i>Inserir coluna depois</button>
                <button @onclick='() => RunCtx("deleteColumn")'><i class="ti ti-column-remove" aria-hidden="true"></i>Excluir coluna</button>
                <button @onclick='() => RunCtx("addRowBefore")'><i class="ti ti-row-insert-top" aria-hidden="true"></i>Inserir linha acima</button>
                <button @onclick='() => RunCtx("addRowAfter")'><i class="ti ti-row-insert-bottom" aria-hidden="true"></i>Inserir linha abaixo</button>
                <button @onclick='() => RunCtx("deleteRow")'><i class="ti ti-row-remove" aria-hidden="true"></i>Excluir linha</button>
                <button @onclick='() => RunCtx("mergeCells")'><i class="ti ti-table-row" aria-hidden="true"></i>Mesclar células</button>
                <button @onclick='() => RunCtx("splitCell")'><i class="ti ti-table-column" aria-hidden="true"></i>Separar célula</button>
                <button @onclick="() => ResizeCell(24, 0)"><i class="ti ti-arrow-autofit-width" aria-hidden="true"></i>Aumentar largura</button>
                <button @onclick="() => ResizeCell(-24, 0)"><i class="ti ti-arrow-autofit-width" aria-hidden="true"></i>Diminuir largura</button>
                <button @onclick="() => ResizeCell(0, 12)"><i class="ti ti-arrow-autofit-height" aria-hidden="true"></i>Aumentar altura</button>
                <button @onclick="() => ResizeCell(0, -12)"><i class="ti ti-arrow-autofit-height" aria-hidden="true"></i>Diminuir altura</button>
                <button class="danger" @onclick='() => RunCtx("deleteTable")'><i class="ti ti-trash" aria-hidden="true"></i>Excluir tabela</button>
            }
            <hr />
            <button @onclick='() => RunCtx("clearFormatting")'><i class="ti ti-clear-formatting" aria-hidden="true"></i>Remover formatação</button>
        }
    </div>
}

@code {
    private static readonly string[] PaletteColors = [
        "#000000", "#343a40", "#495057", "#868e96", "#ced4da", "#f1f3f5", "#ffffff",
        "#c92a2a", "#e03131", "#f03e3e", "#ff6b6b", "#ffa8a8", "#ffd8d8", "#fff5f5",
        "#d9480f", "#e8590c", "#f76707", "#ff922b", "#ffc078", "#ffe8cc", "#fff4e6",
        "#2b8a3e", "#2f9e44", "#37b24d", "#69db7c", "#b2f2bb", "#d3f9d8", "#ebfbee",
        "#1864ab", "#1971c2", "#1c7ed6", "#4dabf7", "#a5d8ff", "#dbe4ff", "#e7f5ff",
        "#5f3dc4", "#6741d9", "#7048e8", "#9775fa", "#d0bfff", "#e5dbff", "#f3f0ff",
    ];

    private const int MaxRecentColors = 7;
    private List<string> _recentFontColors = [];
    private List<string> _recentHighlightColors = [];

    private record CtxMenu(double X, double Y, bool InTable, double CellWidth, double RowHeight, bool IsHeaderCell, bool InImage = false, string ImageSrc = "");

    private string? _ctxColorMode;
    private ElementReference _surface;
    private IJSObjectReference? _module;
    private DotNetObjectReference<RichTextEditor>? _selfRef;
    private string? _lastApplied;

    private string? _activeColorMenu;
    private string _fontColor = "#1f2328";
    private string _highlightColor = "#fff2a8";
    private CtxMenu? _ctxMenu;

    [Parameter] public string? Html { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback OnAttachmentAdded { get; set; }
    [Parameter] public Guid? NoteId { get; set; }
    [Parameter] public IReadOnlyList<AttachmentDto>? ExistingAttachments { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/UltraNote.UI/ultranote-editor.js");
            await _module.InvokeVoidAsync("attach", _surface, _selfRef);
        }

        // Sync external content into the surface (skips while the user is the source of truth).
        if (_module is not null && Html != _lastApplied)
        {
            _lastApplied = Html;
            await _module.InvokeVoidAsync("setHtml", _surface, Html ?? string.Empty);
        }
    }

    public async Task<string> GetHtmlAsync() =>
        _module is null ? string.Empty : await _module.InvokeAsync<string>("getHtml", _surface);

    private async Task Exec(string command, string? arg = null)
    {
        if (_module is null) return;
        await _module.InvokeVoidAsync("exec", _surface, command, arg);
    }

    private async Task InsertLink()
    {
        var url = await JS.InvokeAsync<string>("prompt", "URL do link:");
        if (!string.IsNullOrWhiteSpace(url)) await Exec("link", url);
    }

    private async Task InsertImageFromFile()
    {
        if (_module is null) return;
        await _module.InvokeVoidAsync("insertImageFromFile", _surface, _selfRef);
    }

    [JSInvokable]
    public async Task<string?> UploadImageAsync(string base64, string fileName, string contentType)
    {
        if (NoteId is null) return null;
        try
        {
            var bytes = Convert.FromBase64String(base64);
            using var stream = new MemoryStream(bytes);
            var dto = await Api.UploadAttachmentAsync(NoteId.Value, fileName, contentType, stream, isEmbedded: true);
            return Api.GetAttachmentUrl(dto.Id);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[UltraNote] Image upload failed: {ex.Message}");
            return null;
        }
    }

    [JSInvokable]
    public async Task UploadFileAsync(string base64, string fileName, string contentType)
    {
        if (NoteId is null) return;
        try
        {
            var existing = ExistingAttachments?.FirstOrDefault(a =>
                string.Equals(a.FileName, fileName, StringComparison.OrdinalIgnoreCase));
            if (existing is not null)
            {
                var ok = await JS.InvokeAsync<bool>("confirm",
                    $"Já existe um anexo chamado \"{fileName}\". Deseja substituir?");
                if (!ok) return;
                try { await Api.DeleteAttachmentAsync(existing.Id); } catch { }
            }
            var bytes = Convert.FromBase64String(base64);
            using var stream = new MemoryStream(bytes);
            await Api.UploadAttachmentAsync(NoteId.Value, fileName, contentType, stream);
            await OnAttachmentAdded.InvokeAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[UltraNote] File upload failed: {ex.Message}");
        }
    }

    private void ToggleColorMenu(string which) => _activeColorMenu = _activeColorMenu == which ? null : which;
    private void CloseColorMenus() => _activeColorMenu = null;

    private async Task PickFontColor(string hex)
    {
        _fontColor = hex;
        _activeColorMenu = null;
        AddToRecent(_recentFontColors, hex);
        await Exec("color", hex);
    }

    private async Task PickHighlight(string hex)
    {
        _highlightColor = hex;
        _activeColorMenu = null;
        AddToRecent(_recentHighlightColors, hex);
        await Exec("highlight", hex);
    }

    private static void AddToRecent(List<string> list, string hex)
    {
        list.Remove(hex);
        list.Insert(0, hex);
        if (list.Count > MaxRecentColors) list.RemoveAt(list.Count - 1);
    }

    // ---------- Context menu (right-click in the editor) ----------
    [JSInvokable]
    public void OnEditorContextMenu(double x, double y, bool inTable, double cellWidth, double rowHeight, bool isHeaderCell, bool inImage = false, string imageSrc = "")
    {
        _ctxMenu = new CtxMenu(x, y, inTable, cellWidth, rowHeight, isHeaderCell, inImage, imageSrc);
        StateHasChanged();
    }

    private void CloseCtxMenu() { _ctxMenu = null; _ctxColorMode = null; }

    private void OpenCtxFontColor() => _ctxColorMode = _ctxColorMode == "font" ? null : "font";
    private void OpenCtxHighlight() => _ctxColorMode = _ctxColorMode == "highlight" ? null : "highlight";

    private async Task PickCtxFontColor(string hex)
    {
        _fontColor = hex;
        AddToRecent(_recentFontColors, hex);
        CloseCtxMenu();
        await Exec("color", hex);
    }

    private async Task PickCtxHighlight(string hex)
    {
        _highlightColor = hex;
        AddToRecent(_recentHighlightColors, hex);
        CloseCtxMenu();
        await Exec("highlight", hex);
    }

    private async Task DetachImage()
    {
        var src = _ctxMenu?.ImageSrc ?? "";
        CloseCtxMenu();
        var parts = src.TrimEnd('/').Split('/');
        if (parts.Length > 0 && Guid.TryParse(parts[^1], out var id))
        {
            try { await Api.SetAttachmentEmbeddedAsync(id, false); } catch { }
        }
        await Exec("deleteImage");
        await OnAttachmentAdded.InvokeAsync();
    }

    private async Task DeleteImage()
    {
        var src = _ctxMenu?.ImageSrc ?? "";
        CloseCtxMenu();
        await Exec("deleteImage");
        // Extract attachment ID from URL ending in /api/attachments/{guid}
        var parts = src.TrimEnd('/').Split('/');
        if (parts.Length > 0 && Guid.TryParse(parts[^1], out var id))
        {
            try { await Api.DeleteAttachmentAsync(id); } catch { }
        }
    }

    private async Task RunCtx(string command, string? arg = null)
    {
        CloseCtxMenu();
        await Exec(command, arg);
    }

    private async Task ResizeCell(double widthDelta, double heightDelta)
    {
        if (_ctxMenu is null || _module is null) return;
        var width = Math.Max(40, _ctxMenu.CellWidth + widthDelta);
        var height = Math.Max(22, _ctxMenu.RowHeight + heightDelta);
        var isHeader = _ctxMenu.IsHeaderCell;
        CloseCtxMenu();
        await _module.InvokeVoidAsync("resizeCurrentCell", _surface, width, height, isHeader);
    }

    [JSInvokable]
    public Task NotifyChanged() => OnChanged.InvokeAsync();

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("dispose", _surface); } catch (JSDisconnectedException) { }
            try { await _module.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        _selfRef?.Dispose();
    }
}

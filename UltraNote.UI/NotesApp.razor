@inject IUltraNoteApi Api
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="app">
    <header class="topbar">
        <span class="brand"><i class="ti ti-notebook" aria-hidden="true"></i>UltraNote</span>

        <nav class="breadcrumb">
            @if (_selectedNote is not null)
            {
                @foreach (var seg in BreadcrumbFolders())
                {
                    <span>@seg</span>
                    <i class="ti ti-chevron-right" aria-hidden="true"></i>
                }
                <span class="crumb-current">@_selectedNote.Title</span>
            }
        </nav>

        <div class="topbar-right">
            <div class="search">
                <i class="ti ti-search" aria-hidden="true"></i>
                <input placeholder="Buscar notas…" value="@_query" @oninput="OnSearchInput" />
            </div>
            <button class="icon-btn" title="Tema" @onclick="ToggleTheme"><i class="ti @(_theme == "dark" ? "ti-sun" : "ti-moon")" aria-hidden="true"></i></button>
            <button class="icon-btn" title="Sobre" @onclick="() => _showAbout = true"><i class="ti ti-info-circle" aria-hidden="true"></i></button>
            @TopBarUser
        </div>
    </header>

    <div class="body">
        <aside class="sidebar">
            <div class="sidebar-toolbar">
                <button class="icon-btn" title="Nova pasta" @onclick="ToolbarNewFolder"><i class="ti ti-folder-plus" aria-hidden="true"></i></button>
                <button class="icon-btn" title="Nova nota" @onclick="ToolbarNewNote" disabled="@(_selectedFolderId is null)"><i class="ti ti-file-plus" aria-hidden="true"></i></button>
                <button class="icon-btn" title="Recolher tudo" @onclick="CollapseAll"><i class="ti ti-chevrons-left" aria-hidden="true"></i></button>
                <button class="icon-btn" title="Expandir tudo" @onclick="ToolbarExpandAll"><i class="ti ti-chevrons-right" aria-hidden="true"></i></button>
                <button class="icon-btn" title="Importar do Evernote" @onclick="OpenImport"><i class="ti ti-file-import" aria-hidden="true"></i></button>
                <button class="icon-btn danger" title="Excluir" @onclick="ToolbarDelete" disabled="@(!CanToolbarDelete)"><i class="ti ti-trash" aria-hidden="true"></i></button>
            </div>
            <div class="sidebar-content">
                @if (string.IsNullOrWhiteSpace(_query))
                {
                    <div class="tree-row tree-root @(_selectedFolderId is null ? "active" : "")" @onclick="SelectRoot">
                        <i class="ti ti-notebook folder-ico" aria-hidden="true"></i>
                        <span class="tree-label">Notas</span>
                    </div>
                    <CascadingValue Value="this">
                        @foreach (var root in ChildrenOf(null))
                        {
                            <TreeNode Folder="root" Depth="0" />
                        }
                    </CascadingValue>
                    @if (_folders.Count == 0)
                    {
                        <p class="empty">Use a barra de ferramentas para criar sua primeira pasta.</p>
                    }
                }
                else
                {
                    @foreach (var n in _searchResults)
                    {
                        <div class="tree-note @(n.Id == SelectedNoteId ? "active" : "")"
                             @onclick="() => RequestSelectNote(n.Id)"
                             @oncontextmenu:preventDefault="true"
                             @oncontextmenu="(e) => OpenNoteMenu(n, e)">
                            <i class="ti ti-file-text note-ico" aria-hidden="true"></i>
                            <span class="tree-label">@n.Title</span>
                            <span class="result-folder">@(FolderById(n.FolderId)?.Name)</span>
                        </div>
                    }
                    @if (_searchResults.Count == 0)
                    {
                        <p class="empty">Nada encontrado.</p>
                    }
                }
            </div>
        </aside>

        <section class="editor-panel">
            @if (_treeSelectionIsNote && _selectedNote is not null)
            {
                <div class="editor-head">
                    <input class="title-input" @bind="_title" @bind:event="oninput" />
                    <button class="btn-accent" @onclick="SaveNote" disabled="@_saving">@(_saving ? "Salvando…" : _dirty ? "Salvar *" : "Salvar")</button>
                </div>
                <div class="editor-meta">@_meta</div>
                <RichTextEditor @ref="_editor" Html="@_selectedNote.ContentHtml" OnChanged="MarkDirty" NoteId="@_selectedNote.Id" OnAttachmentAdded="LoadAttachments" ExistingAttachments="_attachments" />
                <div class="attachments-bar" @ref="_attBar">
                    <div class="attachments-header">
                        <i class="ti ti-paperclip" aria-hidden="true"></i>
                        <span>Anexos</span>
                        @if (_attachments.Count > 0)
                        {
                            <span class="attachments-count">@_attachments.Count</span>
                        }
                        <label class="icon-btn att-add-btn" title="Anexar arquivo">
                            <i class="ti ti-plus" aria-hidden="true"></i>
                            <InputFile style="display:none" OnChange="AttachFiles" multiple accept="*/*" />
                        </label>
                    </div>
                    @if (_attachments.Count > 0)
                    {
                        <div class="attachments-list">
                            @foreach (var att in _attachments)
                            {
                                <div class="attachment-item" @ondblclick="() => OpenAttachment(att)" @oncontextmenu:preventDefault="true" @oncontextmenu="(e) => OpenAttachmentMenu(att, e)">
                                    <i class="ti @FileIcon(att.ContentType)" aria-hidden="true"></i>
                                    <span class="att-name" title="@att.FileName">@att.FileName</span>
                                    <a class="icon-btn" href="@Api.GetAttachmentDownloadUrl(att.Id)" target="_blank" title="Baixar"><i class="ti ti-download" aria-hidden="true"></i></a>
                                    <button class="icon-btn danger" title="Excluir anexo" @onclick="() => DeleteAttachment(att)"><i class="ti ti-trash" aria-hidden="true"></i></button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty att-empty">Nenhum arquivo anexado.</p>
                    }
                </div>
            }
            else if (!_treeSelectionIsNote && _selectedFolderId is not null)
            {
                var folderNotes = NotesOf(_selectedFolderId.Value) ?? new List<NoteSummaryDto>();
                <div class="folder-view">
                    <div class="folder-view-header">
                        <i class="ti ti-folder" aria-hidden="true"></i>
                        <span>@(FolderById(_selectedFolderId.Value)?.Name ?? "")</span>
                        <span class="folder-view-count">@folderNotes.Count nota@(folderNotes.Count == 1 ? "" : "s")</span>
                    </div>
                    @if (folderNotes.Count > 0)
                    {
                        <div class="folder-view-list">
                            @foreach (var note in folderNotes)
                            {
                                <div class="folder-view-item" @onclick="() => RequestSelectNote(note.Id)">
                                    <i class="ti ti-file-text" aria-hidden="true"></i>
                                    <span>@note.Title</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty">Nenhuma nota nesta pasta.</p>
                    }
                </div>
            }
            else
            {
                <div class="editor-empty">Selecione uma pasta ou nota para começar.</div>
            }
            <footer class="statusbar">@_status</footer>
        </section>
    </div>

    @if (_ctx is not null)
    {
        <div class="menu-backdrop" @onclick="CloseMenus" @oncontextmenu:preventDefault="true" @oncontextmenu="CloseMenus"></div>
        <div class="menu" style="left:@($"{_ctx.X}px");top:@($"{_ctx.Y}px")">
            @if (_ctx.Kind == "new")
            {
                <button @onclick="() => GuardUnsaved(() => NewNote(_selectedFolderId))" disabled="@(_selectedFolderId is null)"><i class="ti ti-file-plus" aria-hidden="true"></i>Nova nota</button>
                <button @onclick="() => NewFolder(null)"><i class="ti ti-folder-plus" aria-hidden="true"></i>Nova pasta</button>
            }
            else if (_ctx.Kind == "folder")
            {
                <button @onclick="() => GuardUnsaved(() => NewNote(_ctx.Folder!.Id))"><i class="ti ti-file-plus" aria-hidden="true"></i>Nova nota</button>
                <button @onclick="() => NewFolder(_ctx.Folder!.Id)"><i class="ti ti-folder-plus" aria-hidden="true"></i>Nova subpasta</button>
                <hr />
                <button @onclick="() => RenameFolder(_ctx.Folder!)"><i class="ti ti-pencil" aria-hidden="true"></i>Renomear</button>
                <button @onclick="() => OpenMoveFolder(_ctx.Folder!)"><i class="ti ti-folder-symlink" aria-hidden="true"></i>Mover...</button>
                <button class="danger" @onclick="() => DeleteFolder(_ctx.Folder!)"><i class="ti ti-trash" aria-hidden="true"></i>Excluir</button>
            }
            else
            {
                <button @onclick="() => RenameNote(_ctx.Note!)"><i class="ti ti-pencil" aria-hidden="true"></i>Renomear</button>
                <button @onclick="() => OpenMoveNote(_ctx.Note!)"><i class="ti ti-folder-symlink" aria-hidden="true"></i>Mover...</button>
                <button class="danger" @onclick="() => DeleteNote(_ctx.Note!)"><i class="ti ti-trash" aria-hidden="true"></i>Excluir</button>
            }
        </div>
    }

    @if (_attCtx is not null)
    {
        <div class="menu-backdrop" @onclick="CloseAttachmentMenu" @oncontextmenu:preventDefault="true" @oncontextmenu="CloseAttachmentMenu"></div>
        <div class="menu" style="left:@($"{_attCtx.X}px");top:@($"{_attCtx.Y}px")">
            <button @onclick="RenameAttachment"><i class="ti ti-pencil" aria-hidden="true"></i>Renomear</button>
            <button class="danger" @onclick="DeleteAttachmentFromCtx"><i class="ti ti-trash" aria-hidden="true"></i>Excluir</button>
        </div>
    }

    @if (_import is not null)
    {
        <div class="modal-backdrop">
            <div class="modal-card">
                <h2>Importar do Evernote</h2>
                @if (_import.Importing)
                {
                    <p>Importando nota @_import.Done de @_import.Total&hellip;</p>
                    <div class="import-bar"><div class="import-fill" style="width:@(_import.Total > 0 ? (_import.Done * 100 / _import.Total) : 0)%"></div></div>
                }
                else
                {
                    <p>Selecione um arquivo <strong>.enex</strong> exportado pelo Evernote e a pasta destino.</p>
                    <select class="modal-select" @bind="_import.FolderIdStr">
                        <option value="">— pasta destino —</option>
                        @foreach (var f in _folders.OrderBy(f => f.Path))
                        {
                            <option value="@f.Id">@f.Path</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(_import.Status))
                    {
                        <p class="import-status">@_import.Status</p>
                    }
                }
                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="CloseImport" disabled="@_import.Importing">Cancelar</button>
                    @if (!_import.Importing)
                    {
                        <label class="btn-accent" style="cursor:pointer">
                            Escolher arquivo
                            <InputFile style="display:none" OnChange="DoImport" accept=".enex" />
                        </label>
                    }
                </div>
            </div>
        </div>
    }

    @if (_showAbout)
    {
        <div class="modal-backdrop" @onclick="() => _showAbout = false">
            <div class="modal-card about-card" @onclick:stopPropagation="true">
                <div class="about-logo">
                    <svg width="72" height="72" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="50" cy="50" r="50" fill="#0F2535" />
                        <path fill="#C89B3C" d="M50,22 C52.5,37 63,48 78,50 C63,52 52.5,63 50,78 C47.5,63 37,52 22,50 C37,48 47.5,37 50,22Z" />
                    </svg>
                    <span class="about-brand">U L T R A S O F T</span>
                </div>

                <h2 class="about-appname">UltraNote</h2>
                <p class="about-version">@AppVersion</p>
                <p class="about-stack">C# &middot; .NET 10 &middot; Blazor WASM &middot; ASP.NET Core</p>

                <hr class="about-sep" />

                <p class="about-devby">Desenvolvido por</p>
                <p class="about-dev"><strong>Marcus Siqueira</strong></p>
                <p class="about-dev">ChatGPT <em>&ldquo;Raj&rdquo;</em> Codex</p>
                <p class="about-dev">Claude <em>&ldquo;Claudinho&rdquo;</em> Code</p>

                <hr class="about-sep" />

                <a class="about-link" href="https://github.com/mvsiqueira/UltraNote2" target="_blank" rel="noopener">
                    github.com/mvsiqueira/UltraNote2
                </a>
                <p class="about-copy">&copy; 2025&ndash;2026 Ultrasoft</p>

                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="() => _showAbout = false">Fechar</button>
                </div>
            </div>
        </div>
    }

    @if (_pendingAction is not null)
    {
        <div class="modal-backdrop">
            <div class="modal-card">
                <h2>Alterações não salvas</h2>
                <p>A nota atual tem alterações não salvas. Se continuar, elas serão descartadas.</p>
                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="CancelPendingAction">Cancelar</button>
                    <button class="btn-danger" @onclick="ConfirmPendingAction">Descartar e continuar</button>
                </div>
            </div>
        </div>
    }

    @if (_move is not null)
    {
        <div class="modal-backdrop">
            <div class="modal-card">
                <h2>Mover @(_move.Folder is not null ? "pasta" : "nota")</h2>
                <p>Escolha o destino de "@(_move.Folder?.Name ?? _move.Note?.Title)".</p>
                <select class="modal-select" @bind="_moveDestinationValue">
                    @if (_move.Folder is not null)
                    {
                        <option value="@RootSentinel">(raiz)</option>
                    }
                    @foreach (var f in MoveDestinationCandidates())
                    {
                        <option value="@f.Id">@f.Path</option>
                    }
                </select>
                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="CancelMove">Cancelar</button>
                    <button class="btn-accent" @onclick="ConfirmMove">Mover</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? TopBarUser { get; set; }

    private record CtxMenu(double X, double Y, string Kind, FolderDto? Folder, NoteSummaryDto? Note);
    private bool _showAbout;
    private static string AppVersion
    {
        get
        {
            var v = typeof(NotesApp).Assembly.GetName().Version;
            return v is not null ? $"v{v.Major}.{v.Minor}.{v.Build}" : "v2.0";
        }
    }

    private sealed class ImportState { public string FolderIdStr = ""; public bool Importing; public int Total, Done, Failed; public string Status = ""; }
    private ImportState? _import;
    private record AttachmentCtxMenu(double X, double Y, AttachmentDto Attachment);
    private AttachmentCtxMenu? _attCtx;

    private List<FolderDto> _folders = new();
    private ILookup<Guid?, FolderDto> _byParent = Enumerable.Empty<FolderDto>().ToLookup(f => (Guid?)null);
    private readonly HashSet<Guid> _expanded = new();
    private readonly Dictionary<Guid, List<NoteSummaryDto>> _notes = new();

    private Guid? _selectedFolderId;
    private bool _treeSelectionIsNote;
    private NoteDto? _selectedNote;
    private RichTextEditor? _editor;
    private List<AttachmentDto> _attachments = new();
    private string _title = "";
    private string _meta = "";
    private bool _dirty;
    private string _status = "Pronto.";

    private string _query = "";
    private List<NoteSummaryDto> _searchResults = new();

    private CtxMenu? _ctx;
    private Func<Task>? _pendingAction;
    private bool _saving;

    private record MoveCtx(FolderDto? Folder, NoteSummaryDto? Note);
    private const string RootSentinel = "__root__";
    private MoveCtx? _move;
    private string _moveDestinationValue = "";

    private string _theme = "light";
    private IJSObjectReference? _themeJs;
    private IJSObjectReference? _unsavedJs;
    private IJSObjectReference? _shortcutsJs;
    private IJSObjectReference? _dropZoneJs;
    private DotNetObjectReference<NotesApp>? _shortcutsRef;
    private ElementReference _attBar;
    private bool _dropZoneInitialized;

    public Guid? SelectedNoteId => _selectedNote?.Id;
    public Guid? SelectedFolderId => _selectedFolderId;
    public bool TreeSelectionIsNote => _treeSelectionIsNote;

    protected override async Task OnInitializedAsync() => await LoadFolders();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _themeJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-theme.js");
            _theme = await _themeJs.InvokeAsync<string>("getTheme");
            _unsavedJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-unsaved.js");
            _shortcutsJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-shortcuts.js");
            _dropZoneJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-dropzone.js");
            _shortcutsRef = DotNetObjectReference.Create(this);
            await _shortcutsJs.InvokeVoidAsync("init", _shortcutsRef);
            var savedId = await JS.InvokeAsync<string?>("localStorage.getItem", "ultranote_selected_note");
            if (savedId is not null && Guid.TryParse(savedId, out var restoredNoteId))
                await SelectNoteNow(restoredNoteId);
            StateHasChanged();
        }

        if (_dropZoneJs is not null && _shortcutsRef is not null)
        {
            if (_treeSelectionIsNote && _selectedNote is not null && !_dropZoneInitialized)
            {
                _dropZoneInitialized = true;
                await _dropZoneJs.InvokeVoidAsync("init", _attBar, _shortcutsRef);
            }
            else if ((!_treeSelectionIsNote || _selectedNote is null) && _dropZoneInitialized)
            {
                _dropZoneInitialized = false;
                await _dropZoneJs.InvokeVoidAsync("dispose", _attBar);
            }
        }
    }

    // ---------- Tree data (used by TreeNode) ----------
    public IEnumerable<FolderDto> ChildrenOf(Guid? parentId) => _byParent[parentId];
    public bool IsExpanded(Guid id) => _expanded.Contains(id);
    public List<NoteSummaryDto>? NotesOf(Guid id) => _notes.TryGetValue(id, out var l) ? l : null;

    public async Task SelectFolder(FolderDto folder) => await SelectFolderNow(folder);

    public async Task ToggleExpand(FolderDto folder)
    {
        if (!_expanded.Add(folder.Id)) { _expanded.Remove(folder.Id); StateHasChanged(); return; }
        if (!_notes.ContainsKey(folder.Id)) await LoadNotes(folder.Id);
        StateHasChanged();
    }

    private async Task SelectFolderNow(FolderDto folder)
    {
        if (_dirty) { _pendingAction = () => SelectFolderNow(folder); StateHasChanged(); return; }
        _selectedNote = null;
        _title = "";
        _meta = "";
        await SetDirty(false);
        _selectedFolderId = folder.Id;
        _treeSelectionIsNote = false;
        if (_expanded.Add(folder.Id) && !_notes.ContainsKey(folder.Id))
            await LoadNotes(folder.Id);
        StateHasChanged();
    }

    // ---------- Loading ----------
    private async Task LoadFolders()
    {
        try
        {
            _folders = (await Api.GetFoldersAsync()).ToList();
            _byParent = _folders.ToLookup(f => f.ParentId);
        }
        catch (Exception ex) { _status = $"Erro ao carregar pastas: {ex.Message}"; }
    }

    private async Task LoadNotes(Guid folderId)
    {
        try { _notes[folderId] = (await Api.GetNotesAsync(folderId)).ToList(); }
        catch (Exception ex) { _status = $"Erro ao carregar notas: {ex.Message}"; }
    }

    // ---------- Selection ----------

    /// <summary>Entry point from the UI: guards against discarding unsaved edits before switching notes.</summary>
    public void RequestSelectNote(Guid id) => GuardUnsaved(() => SelectNoteNow(id));

    private async Task SelectNoteNow(Guid id)
    {
        _treeSelectionIsNote = true;
        try
        {
            _selectedNote = await Api.GetNoteAsync(id);
            if (_selectedNote is not null)
            {
                _selectedFolderId = _selectedNote.FolderId;
                _title = _selectedNote.Title;
                await SetDirty(false);
                UpdateMeta();
                await ExpandFolder(_selectedNote.FolderId);
                await JS.InvokeVoidAsync("localStorage.setItem", "ultranote_selected_note", id.ToString());
                _status = $"Editando: {_selectedNote.Title}";
            }
            else
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "ultranote_selected_note");
                _status = "Nota não encontrada.";
            }
        }
        catch (Exception ex) { _status = $"Erro ao abrir nota: {ex.Message}"; }
        await LoadAttachments();
        StateHasChanged();
    }

    private async Task ExpandFolder(Guid folderId)
    {
        var folder = FolderById(folderId);
        while (folder is not null)
        {
            _expanded.Add(folder.Id);
            if (!_notes.ContainsKey(folder.Id)) await LoadNotes(folder.Id);
            folder = folder.ParentId.HasValue ? FolderById(folder.ParentId.Value) : null;
        }
    }

    // ---------- Unsaved-changes guard ----------

    /// <summary>Runs immediately if there's nothing unsaved; otherwise asks for confirmation first.</summary>
    private void GuardUnsaved(Func<Task> action)
    {
        if (_dirty) { _pendingAction = action; StateHasChanged(); }
        else { _ = action(); }
    }

    private async Task ConfirmPendingAction()
    {
        var action = _pendingAction;
        _pendingAction = null;
        await SetDirty(false);
        if (action is not null) await action();
    }

    private void CancelPendingAction() => _pendingAction = null;

    private async Task SetDirty(bool value)
    {
        if (_dirty == value) return;
        _dirty = value;
        if (_unsavedJs is not null) await _unsavedJs.InvokeVoidAsync("setGuard", value);
        StateHasChanged();
    }

    private async Task MarkDirty() => await SetDirty(true);

    private async Task SaveNote()
    {
        if (_selectedNote is null || _editor is null || _saving) return;
        _saving = true;
        StateHasChanged();
        try
        {
            var html = await _editor.GetHtmlAsync();
            var updated = await Api.UpdateNoteAsync(_selectedNote.Id, new UpdateNoteRequest(_title, html, null));
            _selectedNote = updated;
            await SetDirty(false);
            UpdateMeta();
            if (_notes.ContainsKey(updated.FolderId)) await LoadNotes(updated.FolderId);
            _status = $"Salvo: {updated.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao salvar: {ex.Message}"; }
        finally { _saving = false; StateHasChanged(); }
    }

    [JSInvokable]
    public async Task OnSaveShortcut()
    {
        if (_selectedNote is not null && !_saving) await SaveNote();
    }

    // ---------- Menus ----------
    private void OpenNewMenu(MouseEventArgs e) => _ctx = new CtxMenu(e.ClientX - 150, e.ClientY + 14, "new", null, null);
    public void OpenFolderMenu(FolderDto f, MouseEventArgs e) { _selectedFolderId = f.Id; _ctx = new CtxMenu(e.ClientX, e.ClientY, "folder", f, null); StateHasChanged(); }
    public void OpenNoteMenu(NoteSummaryDto n, MouseEventArgs e) { _ctx = new CtxMenu(e.ClientX, e.ClientY, "note", null, n); StateHasChanged(); }
    private void CloseMenus() => _ctx = null;

    // ---------- Actions ----------
    private async Task NewFolder(Guid? parentId)
    {
        CloseMenus();
        var name = await Prompt("Nome da pasta:");
        if (string.IsNullOrWhiteSpace(name)) return;
        try
        {
            var created = await Api.CreateFolderAsync(new CreateFolderRequest(parentId, name));
            await LoadFolders();
            if (parentId is { } p) _expanded.Add(p);
            _status = $"Pasta criada: {created.Name}";
        }
        catch (Exception ex) { _status = $"Erro ao criar pasta: {ex.Message}"; }
    }

    private async Task NewNote(Guid? folderId)
    {
        CloseMenus();
        if (folderId is not { } fid) { _status = "Selecione uma pasta primeiro."; return; }
        var title = await Prompt("Título da nota:");
        if (string.IsNullOrWhiteSpace(title)) return;
        try
        {
            var note = await Api.CreateNoteAsync(new CreateNoteRequest(fid, title, "<p></p>"));
            _expanded.Add(fid);
            await LoadNotes(fid);
            await SelectNoteNow(note.Id);
            _status = $"Nota criada: {note.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao criar nota: {ex.Message}"; }
    }

    private async Task RenameFolder(FolderDto folder)
    {
        CloseMenus();
        var name = await Prompt("Novo nome da pasta:", folder.Name);
        if (string.IsNullOrWhiteSpace(name) || name == folder.Name) return;
        try
        {
            await Api.UpdateFolderAsync(folder.Id, new UpdateFolderRequest(name, null));
            await LoadFolders();
            _status = $"Pasta renomeada: {name}";
        }
        catch (Exception ex) { _status = $"Erro ao renomear: {ex.Message}"; }
    }

    private async Task DeleteFolder(FolderDto folder)
    {
        CloseMenus();
        if (!await Confirm($"Excluir a pasta \"{folder.Name}\" e todo o conteúdo?")) return;
        try
        {
            await Api.DeleteFolderAsync(folder.Id);
            _notes.Remove(folder.Id);
            _expanded.Remove(folder.Id);
            if (_selectedNote is not null && IsUnder(_selectedNote.FolderId, folder)) await ClearEditor();
            await LoadFolders();
            if (_selectedFolderId.HasValue && FolderById(_selectedFolderId.Value) is null)
            {
                _selectedFolderId = null;
                _treeSelectionIsNote = false;
            }
            _status = $"Pasta excluída: {folder.Name}";
        }
        catch (Exception ex) { _status = $"Erro ao excluir: {ex.Message}"; }
    }

    private async Task RenameNote(NoteSummaryDto note)
    {
        CloseMenus();
        var title = await Prompt("Novo título da nota:", note.Title);
        if (string.IsNullOrWhiteSpace(title) || title == note.Title) return;
        try
        {
            await Api.UpdateNoteAsync(note.Id, new UpdateNoteRequest(title, null, null));
            if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
            if (_selectedNote?.Id == note.Id) { _selectedNote = await Api.GetNoteAsync(note.Id); _title = _selectedNote?.Title ?? _title; }
            if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
            _status = $"Nota renomeada: {title}";
        }
        catch (Exception ex) { _status = $"Erro ao renomear: {ex.Message}"; }
    }

    private async Task DeleteNote(NoteSummaryDto note)
    {
        CloseMenus();
        if (!await Confirm($"Excluir a nota \"{note.Title}\"?")) return;
        try
        {
            await Api.DeleteNoteAsync(note.Id);
            if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
            if (_selectedNote?.Id == note.Id) await ClearEditor();
            if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
            _status = $"Nota excluída: {note.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao excluir: {ex.Message}"; }
    }

    // ---------- Move ----------
    private void OpenMoveFolder(FolderDto folder)
    {
        CloseMenus();
        _move = new MoveCtx(folder, null);
        _moveDestinationValue = folder.ParentId?.ToString() ?? RootSentinel;
    }

    private void OpenMoveNote(NoteSummaryDto note)
    {
        CloseMenus();
        _move = new MoveCtx(null, note);
        _moveDestinationValue = note.FolderId.ToString();
    }

    private void CancelMove() => _move = null;

    /// <summary>Valid destinations: for a folder, excludes itself and its descendants (would cycle).</summary>
    private IEnumerable<FolderDto> MoveDestinationCandidates()
    {
        if (_move is null) yield break;
        var ordered = _folders.OrderBy(f => f.Path);
        if (_move.Folder is { } folder)
        {
            foreach (var f in ordered)
                if (f.Id != folder.Id && !IsUnder(f.Id, folder)) yield return f;
        }
        else
        {
            foreach (var f in ordered) yield return f;
        }
    }

    private async Task ConfirmMove()
    {
        if (_move is null) return;
        try
        {
            if (_move.Folder is { } folder)
            {
                Guid? destId = _moveDestinationValue == RootSentinel ? null : Guid.Parse(_moveDestinationValue);
                if (destId != folder.ParentId)
                {
                    await Api.UpdateFolderAsync(folder.Id, new UpdateFolderRequest(null, destId));
                    await LoadFolders();
                    if (destId is { } d) _expanded.Add(d);
                    _status = $"Pasta movida: {folder.Name}";
                }
            }
            else if (_move.Note is { } note)
            {
                var destId = Guid.Parse(_moveDestinationValue);
                if (destId != note.FolderId)
                {
                    await Api.UpdateNoteAsync(note.Id, new UpdateNoteRequest(null, null, destId));
                    if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
                    _expanded.Add(destId);
                    await LoadNotes(destId); // always refresh so the moved note appears right away
                    if (_selectedNote?.Id == note.Id)
                    {
                        _selectedNote = await Api.GetNoteAsync(note.Id);
                        _selectedFolderId = _selectedNote?.FolderId;
                    }
                    if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
                    _status = $"Nota movida: {note.Title}";
                }
            }
        }
        catch (Exception ex) { _status = $"Erro ao mover: {ex.Message}"; }
        _move = null;
    }

    // ---------- Search ----------
    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
    }

    private async Task RunSearch()
    {
        foreach (var f in _folders)
            if (!_notes.ContainsKey(f.Id)) await LoadNotes(f.Id);

        var q = _query.Trim();
        _searchResults = _notes.Values.SelectMany(x => x)
            .Where(n => n.Title.Contains(q, StringComparison.OrdinalIgnoreCase))
            .OrderBy(n => n.Title)
            .ToList();
    }

    private void SelectRoot()
    {
        if (_dirty) { _pendingAction = SelectRootNow; StateHasChanged(); return; }
        _selectedFolderId = null;
        _selectedNote = null;
        _title = "";
        _meta = "";
        _treeSelectionIsNote = false;
        StateHasChanged();
    }

    private async Task SelectRootNow()
    {
        _selectedFolderId = null;
        _selectedNote = null;
        _title = "";
        _meta = "";
        _treeSelectionIsNote = false;
        await SetDirty(false);
        StateHasChanged();
    }
    private Task ToolbarNewFolder() => NewFolder(_selectedFolderId);
    private void ToolbarNewNote() => GuardUnsaved(() => NewNote(_selectedFolderId));
    private void CollapseAll() { _expanded.Clear(); StateHasChanged(); }

    private bool CanToolbarDelete =>
        (_treeSelectionIsNote && _selectedNote is not null) ||
        (!_treeSelectionIsNote && _selectedFolderId is not null);

    private async Task ToolbarDelete()
    {
        if (_treeSelectionIsNote && _selectedNote is not null)
        {
            var note = _selectedNote;
            if (!await Confirm($"Excluir a nota \"{note.Title}\"?")) return;
            try
            {
                await Api.DeleteNoteAsync(note.Id);
                if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
                await ClearEditor();
                if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
                _status = $"Nota excluida: {note.Title}";
            }
            catch (Exception ex) { _status = $"Erro ao excluir: {ex.Message}"; }
        }
        else if (_selectedFolderId is not null)
        {
            var folder = _folders.FirstOrDefault(f => f.Id == _selectedFolderId);
            if (folder is null) return;
            await DeleteFolder(folder);
        }
    }

    private async Task ToolbarExpandAll()
    {
        foreach (var f in _folders) { _expanded.Add(f.Id); if (!_notes.ContainsKey(f.Id)) await LoadNotes(f.Id); }
        StateHasChanged();
    }

    // ---------- Theme ----------
    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        if (_themeJs is not null) await _themeJs.InvokeVoidAsync("setTheme", _theme);
    }

    // ---------- Helpers ----------
    private FolderDto? FolderById(Guid id) => _folders.FirstOrDefault(f => f.Id == id);

    private IEnumerable<string> BreadcrumbFolders()
    {
        if (_selectedNote is null) return Enumerable.Empty<string>();
        var path = FolderById(_selectedNote.FolderId)?.Path;
        return string.IsNullOrEmpty(path) ? Enumerable.Empty<string>() : path.Split('/');
    }

    private bool IsUnder(Guid noteFolderId, FolderDto folder)
    {
        var nf = FolderById(noteFolderId);
        if (nf is null) return false;
        return nf.Id == folder.Id || nf.Path == folder.Path || nf.Path.StartsWith(folder.Path + "/");
    }

    private async Task ClearEditor()
    {
        _selectedNote = null;
        _treeSelectionIsNote = false;
        _title = "";
        _meta = "";
        _attachments.Clear();
        await SetDirty(false);
        await JS.InvokeVoidAsync("localStorage.removeItem", "ultranote_selected_note");
    }

    private void UpdateMeta()
    {
        if (_selectedNote is null) { _meta = ""; return; }
        var words = WordCount(_selectedNote.ContentHtml);
        _meta = $"editada {_selectedNote.UpdatedAt.ToLocalTime():g} · {words} palavra{(words == 1 ? "" : "s")}";
    }

    private static int WordCount(string html)
    {
        var text = System.Text.RegularExpressions.Regex.Replace(html ?? "", "<[^>]+>", " ");
        text = System.Net.WebUtility.HtmlDecode(text);
        return text.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries).Length;
    }

    // ---------- Attachments ----------

    [JSInvokable]
    public async Task UploadFileAsync(string base64, string fileName, string contentType)
    {
        if (_selectedNote is null) return;
        try
        {
            var existing = _attachments.FirstOrDefault(a =>
                string.Equals(a.FileName, fileName, StringComparison.OrdinalIgnoreCase));
            if (existing is not null)
            {
                if (!await Confirm($"Já existe um anexo chamado \"{fileName}\". Deseja substituir?"))
                    return;
                try { await Api.DeleteAttachmentAsync(existing.Id); } catch { }
            }
            var bytes = Convert.FromBase64String(base64);
            using var stream = new MemoryStream(bytes);
            await Api.UploadAttachmentAsync(_selectedNote.Id, fileName, contentType, stream);
            await LoadAttachments();
            StateHasChanged();
        }
        catch (Exception ex) { _status = $"Erro ao anexar {fileName}: {ex.Message}"; StateHasChanged(); }
    }

    private async Task LoadAttachments()
    {
        if (_selectedNote is null) { _attachments.Clear(); return; }
        try
        {
            var all = await Api.GetAttachmentsAsync(_selectedNote.Id);
            _attachments = all.Where(a => !a.IsEmbedded).ToList();
        }
        catch { _attachments.Clear(); }
    }

    private async Task AttachFiles(InputFileChangeEventArgs e)
    {
        if (_selectedNote is null) return;
        foreach (var file in e.GetMultipleFiles(20))
        {
            try
            {
                var existing = _attachments.FirstOrDefault(a =>
                    string.Equals(a.FileName, file.Name, StringComparison.OrdinalIgnoreCase));
                if (existing is not null)
                {
                    if (!await Confirm($"Já existe um anexo chamado \"{file.Name}\". Deseja substituir?"))
                        continue;
                    try { await Api.DeleteAttachmentAsync(existing.Id); } catch { }
                    _attachments.Remove(existing);
                }
                await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
                var dto = await Api.UploadAttachmentAsync(_selectedNote.Id, file.Name, file.ContentType, stream);
                _attachments.Add(dto);
            }
            catch (Exception ex) { _status = $"Erro ao anexar {file.Name}: {ex.Message}"; }
        }
        StateHasChanged();
    }

    private async Task OpenAttachment(AttachmentDto att) =>
        await JS.InvokeVoidAsync("open", Api.GetAttachmentUrl(att.Id), "_blank");

    private void OpenAttachmentMenu(AttachmentDto att, MouseEventArgs e) =>
        _attCtx = new AttachmentCtxMenu(e.ClientX, e.ClientY, att);

    private void CloseAttachmentMenu() => _attCtx = null;

    private async Task RenameAttachment()
    {
        if (_attCtx is null) return;
        var att = _attCtx.Attachment;
        CloseAttachmentMenu();
        var newName = await Prompt("Novo nome do arquivo:", att.FileName);
        if (string.IsNullOrWhiteSpace(newName) || newName == att.FileName) return;
        try
        {
            var updated = await Api.RenameAttachmentAsync(att.Id, newName);
            var idx = _attachments.IndexOf(att);
            if (idx >= 0) _attachments[idx] = updated;
            StateHasChanged();
        }
        catch (Exception ex) { _status = $"Erro ao renomear anexo: {ex.Message}"; }
    }

    private async Task DeleteAttachmentFromCtx()
    {
        if (_attCtx is null) return;
        var att = _attCtx.Attachment;
        CloseAttachmentMenu();
        await DeleteAttachment(att);
    }

    private async Task DeleteAttachment(AttachmentDto att)
    {
        if (!await Confirm($"Excluir o anexo \"{att.FileName}\"?")) return;
        try
        {
            await Api.DeleteAttachmentAsync(att.Id);
            _attachments.Remove(att);
            StateHasChanged();
        }
        catch (Exception ex) { _status = $"Erro ao excluir anexo: {ex.Message}"; }
    }

    private static string FileIcon(string ct) => ct switch
    {
        _ when ct.StartsWith("image/") => "ti-photo",
        _ when ct.Contains("pdf") => "ti-file-type-pdf",
        _ when ct.Contains("word") || ct.Contains("document") => "ti-file-type-doc",
        _ when ct.Contains("sheet") || ct.Contains("excel") || ct.Contains("spreadsheet") => "ti-file-type-xls",
        _ when ct.Contains("zip") || ct.Contains("compressed") || ct.Contains("x-tar") => "ti-file-zip",
        _ when ct.Contains("text/") => "ti-file-text",
        _ => "ti-file",
    };

    // ---------- Evernote import ----------

    private void OpenImport() => _import = new ImportState();
    private void CloseImport() => _import = null;

    private async Task DoImport(InputFileChangeEventArgs e)
    {
        if (_import is null) return;
        if (!Guid.TryParse(_import.FolderIdStr, out var folderId))
        {
            _import.Status = "Selecione uma pasta de destino.";
            return;
        }

        // Read file BEFORE StateHasChanged — re-rendering invalidates the InputFile reference
        using var buf = new MemoryStream();
        try
        {
            await using var raw = e.File.OpenReadStream(maxAllowedSize: 200L * 1024 * 1024);
            await raw.CopyToAsync(buf);
        }
        catch (Exception ex)
        {
            _import.Status = $"Erro ao ler arquivo: {ex.Message}";
            return;
        }
        buf.Position = 0;

        _import.Importing = true;
        _import.Done = 0;
        _import.Failed = 0;
        _import.Status = "";
        StateHasChanged();

        try
        {
            var notes = EnexImporter.Parse(buf);

            _import.Total = notes.Count;
            StateHasChanged();

            foreach (var note in notes)
            {
                try
                {
                    // Create empty note to obtain the ID
                    var created = await Api.CreateNoteAsync(new CreateNoteRequest(folderId, note.Title, "<p></p>"));

                    // Upload resources; images become embedded, others become attachments
                    var hashToUrl = new Dictionary<string, string>();
                    foreach (var res in note.Resources)
                    {
                        try
                        {
                            using var ms = new MemoryStream(res.Data);
                            var dto = await Api.UploadAttachmentAsync(
                                created.Id, res.FileName, res.Mime, ms,
                                isEmbedded: res.Mime.StartsWith("image/"));
                            hashToUrl[res.Hash] = Api.GetAttachmentUrl(dto.Id);
                        }
                        catch { }
                    }

                    // Convert ENML → HTML and persist the final content
                    var html = EnexImporter.ConvertEnml(note.RawEnml, hashToUrl);
                    await Api.UpdateNoteAsync(created.Id, new UpdateNoteRequest(note.Title, html, null));

                    _import.Done++;
                }
                catch { _import.Failed++; }
                StateHasChanged();
            }

            await LoadNotes(folderId);
            _import.Status = _import.Failed == 0
                ? $"{_import.Done} nota(s) importada(s) com sucesso."
                : $"{_import.Done} importada(s), {_import.Failed} falha(s).";
        }
        catch (Exception ex)
        {
            _import.Status = $"Erro ao ler arquivo: {ex.Message}";
        }

        _import.Importing = false;
        StateHasChanged();
    }

    private async Task<string?> Prompt(string message, string? def = null) =>
        await JS.InvokeAsync<string?>("prompt", message, def ?? "");

    private async Task<bool> Confirm(string message) => await JS.InvokeAsync<bool>("confirm", message);

    public async ValueTask DisposeAsync()
    {
        if (_themeJs is not null)
        {
            try { await _themeJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        if (_unsavedJs is not null)
        {
            try { await _unsavedJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        if (_shortcutsJs is not null)
        {
            try { await _shortcutsJs.InvokeVoidAsync("dispose"); await _shortcutsJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        if (_dropZoneJs is not null)
        {
            try { if (_dropZoneInitialized) await _dropZoneJs.InvokeVoidAsync("dispose", _attBar); } catch (JSDisconnectedException) { }
            try { await _dropZoneJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        _shortcutsRef?.Dispose();
    }

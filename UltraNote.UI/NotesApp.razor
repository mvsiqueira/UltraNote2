    public async Task ToggleFavorite(NoteSummaryDto note)
    {
        CloseMenus();
        var newVal = !note.IsFavorite;
        try
        {
            await Api.UpdateNoteAsync(note.Id, new UpdateNoteRequest(null, null, null, newVal));
            // Atualiza cache da pasta
            if (_notes.TryGetValue(note.FolderId, out var list))
            {
                var idx = list.FindIndex(n => n.Id == note.Id);
                if (idx >= 0) list[idx] = list[idx] with { IsFavorite = newVal };
            }
            // Atualiza resultados de busca
            var sri = _searchResults.FindIndex(n => n.Id == note.Id);
            if (sri >= 0) _searchResults[sri] = _searchResults[sri] with { IsFavorite = newVal };
            // Atualiza nota aberta se for a mesma
            if (_selectedNote?.Id == note.Id)
                _selectedNote = _selectedNote with { IsFavorite = newVal };
            await LoadFavorites();
            StateHasChanged();
        }
        catch (Exception ex) { _status = $"Erro: {ex.Message}"; }
    }

    private Task ToggleFavoriteCurrentNote()
    {
        if (_selectedNote is null) return Task.CompletedTask;
        // Busca summary no cache para reutilizar ToggleFavorite
        if (_notes.TryGetValue(_selectedNote.FolderId, out var list))
        {
            var s = list.FirstOrDefault(n => n.Id == _selectedNote.Id);
            if (s is not null) return ToggleFavorite(s);
        }
        // Fallback: constrói summary a partir da nota aberta
        return ToggleFavorite(new NoteSummaryDto(
            _selectedNote.Id, _selectedNote.FolderId, _selectedNote.Title,
            _selectedNote.UpdatedAt, _selectedNote.IsFavorite, _selectedNote.IsArchived));
    }

    public async Task ToggleArchive(NoteSummaryDto note)
    {
        CloseMenus();
        var newVal = !note.IsArchived;
        try
        {
            await Api.UpdateNoteAsync(note.Id, new UpdateNoteRequest(null, null, null, IsArchived: newVal));
            if (_notes.TryGetValue(note.FolderId, out var list))
            {
                var idx = list.FindIndex(n => n.Id == note.Id);
                if (idx >= 0) list[idx] = list[idx] with { IsArchived = newVal };
            }
            var sri = _searchResults.FindIndex(n => n.Id == note.Id);
            if (sri >= 0) _searchResults[sri] = _searchResults[sri] with { IsArchived = newVal };
            if (_selectedNote?.Id == note.Id)
                _selectedNote = _selectedNote with { IsArchived = newVal };
            var favIdx = _favorites.FindIndex(n => n.Id == note.Id);
            if (favIdx >= 0) _favorites[favIdx] = _favorites[favIdx] with { IsArchived = newVal };
            await LoadArchivedCount();
            StateHasChanged();
        }
        catch (Exception ex) { _status = $"Erro: {ex.Message}"; }
    }

    private Task ToggleArchiveCurrentNote()
    {
        if (_selectedNote is null) return Task.CompletedTask;
        if (_notes.TryGetValue(_selectedNote.FolderId, out var list))
        {
            var s = list.FirstOrDefault(n => n.Id == _selectedNote.Id);
            if (s is not null) return ToggleArchive(s);
        }
        return ToggleArchive(new NoteSummaryDto(
            _selectedNote.Id, _selectedNote.FolderId, _selectedNote.Title,
            _selectedNote.UpdatedAt, _selectedNote.IsFavorite, _selectedNote.IsArchived));
    }

    // ---------- Selection ----------

    /// <summary>Entry point from the UI: guards against discarding unsaved edits before switching notes.</summary>
    public void RequestSelectNote(Guid id) => GuardUnsaved(() => SelectNoteNow(id));

    private async Task SelectNoteNow(Guid id)
    {
        _treeSelectionIsNote = true;
        try
        {
            _selectedNote = await Api.GetNoteAsync(id);
            if (_selectedNote is not null)
            {
                _selectedFolderId = _selectedNote.FolderId;
                _title = _selectedNote.Title;
                await SetDirty(false);
                UpdateMeta();
                await ExpandFolder(_selectedNote.FolderId);
                await JS.InvokeVoidAsync("localStorage.setItem", "ultranote_selected_note", id.ToString());
                _status = $"Editando: {_selectedNote.Title}";
            }
            else
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "ultranote_selected_note");
                _status = "Nota não encontrada.";
            }
        }
        catch (Exception ex) { _status = $"Erro ao abrir nota: {ex.Message}"; }
        await LoadAttachments();
        StateHasChanged();
    }

    private async Task ExpandFolder(Guid folderId)
    {
        var folder = FolderById(folderId);
        while (folder is not null)
        {
            _expanded.Add(folder.Id);
            if (!_notes.ContainsKey(folder.Id)) await LoadNotes(folder.Id);
            folder = folder.ParentId.HasValue ? FolderById(folder.ParentId.Value) : null;
        }
    }

    // ---------- Unsaved-changes guard ----------

    /// <summary>Runs immediately if there's nothing unsaved; otherwise asks for confirmation first.</summary>
    private void GuardUnsaved(Func<Task> action)
    {
        if (_dirty) { _pendingAction = action; StateHasChanged(); }
        else { _ = action(); }
    }

    private async Task ConfirmPendingAction()
    {
        var action = _pendingAction;
        _pendingAction = null;
        await SetDirty(false);
        if (action is not null) await action();
    }

    private void CancelPendingAction() => _pendingAction = null;

    private async Task SetDirty(bool value)
    {
        if (_dirty == value) return;
        _dirty = value;
        if (_unsavedJs is not null) await _unsavedJs.InvokeVoidAsync("setGuard", value);
        StateHasChanged();
    }

    private async Task MarkDirty() => await SetDirty(true);

    private async Task SaveNote()
    {
        if (_selectedNote is null || _editor is null || _saving) return;
        _saving = true;
        StateHasChanged();
        try
        {
            var html = await _editor.GetHtmlAsync();
            var updated = await Api.UpdateNoteAsync(_selectedNote.Id, new UpdateNoteRequest(_title, html, null));
            _selectedNote = updated;
            await SetDirty(false);
            UpdateMeta();
            if (_notes.ContainsKey(updated.FolderId)) await LoadNotes(updated.FolderId);
            _status = $"Salvo: {updated.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao salvar: {ex.Message}"; }
        finally { _saving = false; StateHasChanged(); }
    }

    [JSInvokable]
    public async Task OnSaveShortcut()
    {
        if (_selectedNote is not null && !_saving) await SaveNote();
    }


    protected override async Task OnInitializedAsync()
    {
        await LoadFolders();
        await LoadFavorites();
        await LoadArchivedCount();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _themeJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-theme.js");
            _theme = await _themeJs.InvokeAsync<string>("getTheme");
            _unsavedJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-unsaved.js");
            _shortcutsJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-shortcuts.js");
            _dropZoneJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-dropzone.js");
            _sidebarResizeJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-sidebar-resize.js");
            _downloadJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-download.js");
            await _sidebarResizeJs.InvokeVoidAsync("init", _bodyEl, _resizeHandle);
            _shortcutsRef = DotNetObjectReference.Create(this);
            await _shortcutsJs.InvokeVoidAsync("init", _shortcutsRef);
            var savedId = await JS.InvokeAsync<string?>("localStorage.getItem", "ultranote_selected_note");
            if (savedId is not null && Guid.TryParse(savedId, out var restoredNoteId))
                await SelectNoteNow(restoredNoteId);
            var savedFavVisible = await JS.InvokeAsync<string?>("localStorage.getItem", "ultranote_favorites_visible");
            if (savedFavVisible is not null) _favoritesVisible = savedFavVisible == "true";
            var savedShowArchived = await JS.InvokeAsync<string?>("localStorage.getItem", "ultranote_show_archived");
            if (savedShowArchived is not null) _showArchived = savedShowArchived == "true";
            StateHasChanged();
        }

        if (_dropZoneJs is not null && _shortcutsRef is not null)
        {
            if (_treeSelectionIsNote && _selectedNote is not null && !_dropZoneInitialized)
            {
                _dropZoneInitialized = true;
                await _dropZoneJs.InvokeVoidAsync("init", _attBar, _shortcutsRef);
            }
            else if ((!_treeSelectionIsNote || _selectedNote is null) && _dropZoneInitialized)
            {
                _dropZoneInitialized = false;
                await _dropZoneJs.InvokeVoidAsync("dispose", _attBar);
            }
        }
    }

    // ---------- Tree data (used by TreeNode) ----------
    public IEnumerable<FolderDto> ChildrenOf(Guid? parentId) => _byParent[parentId];
    public bool IsExpanded(Guid id) => _expanded.Contains(id);
    public List<NoteSummaryDto>? NotesOf(Guid id) => _notes.TryGetValue(id, out var l) ? l : null;

    public async Task SelectFolder(FolderDto folder) => await SelectFolderNow(folder);

    public async Task ToggleExpand(FolderDto folder)
    {
        if (!_expanded.Add(folder.Id)) { _expanded.Remove(folder.Id); StateHasChanged(); return; }
        if (!_notes.ContainsKey(folder.Id)) await LoadNotes(folder.Id);
        StateHasChanged();
    }

    // ---------- Drag and drop (move via dragging onto a folder / the root row) ----------
    private object? _dragging; // FolderDto or NoteSummaryDto currently being dragged
    private Guid? _dragOverFolderId;
    private bool _dragOverRoot;

    public void StartDragFolder(FolderDto folder) => _dragging = folder;
    public void StartDragNote(NoteSummaryDto note) => _dragging = note;
    public bool IsDragOver(Guid folderId) => _dragOverFolderId == folderId;
    public void DragEnterFolder(Guid folderId) => _dragOverFolderId = folderId;
    public void DragLeaveFolder(Guid folderId) { if (_dragOverFolderId == folderId) _dragOverFolderId = null; }

    public async Task DropOnFolder(Guid targetFolderId)
    {
        _dragOverFolderId = null;
        var dragging = _dragging;
        _dragging = null;
        switch (dragging)
        {
            case FolderDto df when df.Id != targetFolderId:
                _move = new MoveCtx(df, null);
                _moveDestinationValue = targetFolderId.ToString();
                await ConfirmMove();
                break;
            case NoteSummaryDto dn:
                _move = new MoveCtx(null, dn);
                _moveDestinationValue = targetFolderId.ToString();
                await ConfirmMove();
                break;
        }
        // The drop lands on a *child* TreeNode's event handler, so Blazor only
        // auto-rerenders that instance — force a rerender from the root so every
        // TreeNode (including the note/folder's OLD location, a sibling instance)
        // picks up the change instead of looking stale until clicked.
        StateHasChanged();
    }

    private async Task DropOnRoot()
    {
        _dragOverRoot = false;
        var dragging = _dragging;
        _dragging = null;
        // Notes always need a folder — dropping one on the root row is a no-op.
        if (dragging is FolderDto df)
        {
            _move = new MoveCtx(df, null);
            _moveDestinationValue = RootSentinel;
            await ConfirmMove();
        }
        StateHasChanged();
    }

    private async Task SelectFolderNow(FolderDto folder)
    {
        if (_dirty) { _pendingAction = () => SelectFolderNow(folder); StateHasChanged(); return; }
        _selectedNote = null;
        _title = "";
        _meta = "";
        await SetDirty(false);
        _selectedFolderId = folder.Id;
        _treeSelectionIsNote = false;
        if (!_expanded.Add(folder.Id))
            _expanded.Remove(folder.Id);
        else if (!_notes.ContainsKey(folder.Id))
            await LoadNotes(folder.Id);
        StateHasChanged();
    }


    // ---------- Actions ----------
    private async Task NewFolder(Guid? parentId)
    {
        CloseMenus();
        var name = await Prompt("Nome da pasta:");
        if (string.IsNullOrWhiteSpace(name)) return;
        try
        {
            var created = await Api.CreateFolderAsync(new CreateFolderRequest(parentId, name));
            await LoadFolders();
            if (parentId is { } p) _expanded.Add(p);
            _status = $"Pasta criada: {created.Name}";
        }
        catch (Exception ex) { _status = $"Erro ao criar pasta: {ex.Message}"; }
    }

    private async Task NewNote(Guid? folderId)
    {
        CloseMenus();
        if (folderId is not { } fid) { _status = "Selecione uma pasta primeiro."; return; }
        var title = await Prompt("Título da nota:");
        if (string.IsNullOrWhiteSpace(title)) return;
        try
        {
            var note = await Api.CreateNoteAsync(new CreateNoteRequest(fid, title, "<p></p>"));
            _expanded.Add(fid);
            await LoadNotes(fid);
            await SelectNoteNow(note.Id);
            _status = $"Nota criada: {note.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao criar nota: {ex.Message}"; }
    }

    private async Task RenameFolder(FolderDto folder)
    {
        CloseMenus();
        var name = await Prompt("Novo nome da pasta:", folder.Name);
        if (string.IsNullOrWhiteSpace(name) || name == folder.Name) return;
        try
        {
            await Api.UpdateFolderAsync(folder.Id, new UpdateFolderRequest(name, folder.ParentId));
            await LoadFolders();
            _status = $"Pasta renomeada: {name}";
        }
        catch (Exception ex) { _status = $"Erro ao renomear: {ex.Message}"; }
    }

    private async Task DeleteFolder(FolderDto folder)
    {
        CloseMenus();
        var archivedCount = 0;
        try { archivedCount = await Api.GetFolderArchivedCountAsync(folder.Id); } catch { }
        var message = archivedCount > 0
            ? $"Excluir a pasta \"{folder.Name}\" e todo o conteúdo? Isso inclui {archivedCount} nota(s) arquivada(s)."
            : $"Excluir a pasta \"{folder.Name}\" e todo o conteúdo?";
        if (!await Confirm(message)) return;
        try
        {
            await Api.DeleteFolderAsync(folder.Id);
            _notes.Remove(folder.Id);
            _expanded.Remove(folder.Id);
            if (_selectedNote is not null && IsUnder(_selectedNote.FolderId, folder)) await ClearEditor();
            await LoadFolders();
            if (archivedCount > 0) { await LoadArchivedCount(); await LoadFavorites(); }
            if (_selectedFolderId.HasValue && FolderById(_selectedFolderId.Value) is null)
            {
                _selectedFolderId = null;
                _treeSelectionIsNote = false;
            }
            _status = $"Pasta excluída: {folder.Name}";
        }
        catch (Exception ex) { _status = $"Erro ao excluir: {ex.Message}"; }
    }

    private async Task RenameNote(NoteSummaryDto note)
    {
        CloseMenus();
        var title = await Prompt("Novo título da nota:", note.Title);
        if (string.IsNullOrWhiteSpace(title) || title == note.Title) return;
        try
        {
            await Api.UpdateNoteAsync(note.Id, new UpdateNoteRequest(title, null, null));
            if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
            if (_selectedNote?.Id == note.Id) { _selectedNote = await Api.GetNoteAsync(note.Id); _title = _selectedNote?.Title ?? _title; }
            if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
            _status = $"Nota renomeada: {title}";
        }
        catch (Exception ex) { _status = $"Erro ao renomear: {ex.Message}"; }
    }

    private async Task DeleteNote(NoteSummaryDto note)
    {
        CloseMenus();
        if (!await Confirm($"Excluir a nota \"{note.Title}\"?")) return;
        try
        {
            await Api.DeleteNoteAsync(note.Id);
            if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
            if (_selectedNote?.Id == note.Id) await ClearEditor();
            if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
            _status = $"Nota excluída: {note.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao excluir: {ex.Message}"; }
    }

    // ---------- Move ----------
    private void OpenMoveFolder(FolderDto folder)
    {
        CloseMenus();
        _move = new MoveCtx(folder, null);
        _moveDestinationValue = folder.ParentId?.ToString() ?? RootSentinel;
    }

    private void OpenMoveNote(NoteSummaryDto note)
    {
        CloseMenus();
        _move = new MoveCtx(null, note);
        _moveDestinationValue = note.FolderId.ToString();
    }

    private void CancelMove() => _move = null;

    /// <summary>Valid destinations: for a folder, excludes itself and its descendants (would cycle).</summary>
    private IEnumerable<FolderDto> MoveDestinationCandidates()
    {
        if (_move is null) yield break;
        var ordered = _folders.OrderBy(f => f.Path);
        if (_move.Folder is { } folder)
        {
            foreach (var f in ordered)
                if (f.Id != folder.Id && !IsUnder(f.Id, folder)) yield return f;
        }
        else
        {
            foreach (var f in ordered) yield return f;
        }
    }

    private async Task ConfirmMove()
    {
        if (_move is null) return;
        try
        {
            if (_move.Folder is { } folder)
            {
                Guid? destId = _moveDestinationValue == RootSentinel ? null : Guid.Parse(_moveDestinationValue);
                if (destId != folder.ParentId)
                {
                    await Api.UpdateFolderAsync(folder.Id, new UpdateFolderRequest(null, destId));
                    await LoadFolders();
                    if (destId is { } d) _expanded.Add(d);
                    _status = $"Pasta movida: {folder.Name}";
                }
            }
            else if (_move.Note is { } note)
            {
                var destId = Guid.Parse(_moveDestinationValue);
                if (destId != note.FolderId)
                {
                    await Api.UpdateNoteAsync(note.Id, new UpdateNoteRequest(null, null, destId));
                    if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
                    _expanded.Add(destId);
                    await LoadNotes(destId); // always refresh so the moved note appears right away
                    if (_selectedNote?.Id == note.Id)
                    {
                        _selectedNote = await Api.GetNoteAsync(note.Id);
                        _selectedFolderId = _selectedNote?.FolderId;
                    }
                    if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
                    _status = $"Nota movida: {note.Title}";
                }
            }
        }
        catch (Exception ex) { _status = $"Erro ao mover: {ex.Message}"; }
        _move = null;
    }

    // ---------- Search ----------
    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
    }

    private async Task RunSearch()
    {
        foreach (var f in _folders)
            if (!_notes.ContainsKey(f.Id)) await LoadNotes(f.Id);

        var q = _query.Trim();
        _searchResults = _notes.Values.SelectMany(x => x)
            .Where(n => n.Title.Contains(q, StringComparison.OrdinalIgnoreCase))
            .Where(n => _showArchived || !n.IsArchived)
            .OrderBy(n => n.Title)
            .ToList();
    }

    private void SelectRoot()
    {
        if (_dirty) { _pendingAction = SelectRootNow; StateHasChanged(); return; }
        _selectedFolderId = null;
        _selectedNote = null;
        _title = "";
        _meta = "";
        _treeSelectionIsNote = false;
        StateHasChanged();
    }

    private async Task SelectRootNow()
    {
        _selectedFolderId = null;
        _selectedNote = null;
        _title = "";
        _meta = "";
        _treeSelectionIsNote = false;
        await SetDirty(false);
        StateHasChanged();
    }
    private Task ToolbarNewFolder() => NewFolder(_selectedFolderId);
    private void ToolbarNewNote() => GuardUnsaved(() => NewNote(_selectedFolderId));
    private void CollapseAll() { _expanded.Clear(); StateHasChanged(); }

    private bool CanToolbarDelete =>
        (_treeSelectionIsNote && _selectedNote is not null) ||
        (!_treeSelectionIsNote && _selectedFolderId is not null);

    private async Task ToolbarDelete()
    {
        if (_treeSelectionIsNote && _selectedNote is not null)
        {
            var note = _selectedNote;
            if (!await Confirm($"Excluir a nota \"{note.Title}\"?")) return;
            try
            {
                await Api.DeleteNoteAsync(note.Id);
                if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
                await ClearEditor();
                if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
                _status = $"Nota excluida: {note.Title}";
            }
            catch (Exception ex) { _status = $"Erro ao excluir: {ex.Message}"; }
        }
        else if (_selectedFolderId is not null)
        {
            var folder = _folders.FirstOrDefault(f => f.Id == _selectedFolderId);
            if (folder is null) return;
            await DeleteFolder(folder);
        }
    }

    private async Task ToolbarExpandAll()
    {
        foreach (var f in _folders) { _expanded.Add(f.Id); if (!_notes.ContainsKey(f.Id)) await LoadNotes(f.Id); }
        StateHasChanged();
    }

    // ---------- Theme ----------
    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        if (_themeJs is not null) await _themeJs.InvokeVoidAsync("setTheme", _theme);
    }

    // ---------- Helpers ----------
    private FolderDto? FolderById(Guid id) => _folders.FirstOrDefault(f => f.Id == id);

    private IEnumerable<string> BreadcrumbFolders()
    {
        if (_selectedNote is null) return Enumerable.Empty<string>();
        var path = FolderById(_selectedNote.FolderId)?.Path;
        return string.IsNullOrEmpty(path) ? Enumerable.Empty<string>() : path.Split('/');
    }

    private bool IsUnder(Guid noteFolderId, FolderDto folder)
    {
        var nf = FolderById(noteFolderId);
        if (nf is null) return false;
        return nf.Id == folder.Id || nf.Path == folder.Path || nf.Path.StartsWith(folder.Path + "/");
    }

    private async Task ClearEditor()
    {
        _selectedNote = null;
        _treeSelectionIsNote = false;
        _title = "";
        _meta = "";
        _attachments.Clear();
        await SetDirty(false);
        await JS.InvokeVoidAsync("localStorage.removeItem", "ultranote_selected_note");
    }

    private void UpdateMeta()
    {
        if (_selectedNote is null) { _meta = ""; return; }
        var words = WordCount(_selectedNote.ContentHtml);
        _meta = $"editada {_selectedNote.UpdatedAt.ToLocalTime():g} · {words} palavra{(words == 1 ? "" : "s")}";
    }

    private static int WordCount(string html)
    {
        var text = System.Text.RegularExpressions.Regex.Replace(html ?? "", "<[^>]+>", " ");
        text = System.Net.WebUtility.HtmlDecode(text);
        return text.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries).Length;
    }

    // ---------- Attachments ----------

    [JSInvokable]
    public async Task UploadFileAsync(string base64, string fileName, string contentType)
    {
        if (_selectedNote is null) return;
        try
        {
            var existing = _attachments.FirstOrDefault(a =>
                string.Equals(a.FileName, fileName, StringComparison.OrdinalIgnoreCase));
            if (existing is not null)
            {
                if (!await Confirm($"Já existe um anexo chamado \"{fileName}\". Deseja substituir?"))
                    return;
                try { await Api.DeleteAttachmentAsync(existing.Id); } catch { }
            }
            var bytes = Convert.FromBase64String(base64);
            using var stream = new MemoryStream(bytes);
            await Api.UploadAttachmentAsync(_selectedNote.Id, fileName, contentType, stream);
            await LoadAttachments();
            StateHasChanged();
        }
        catch (Exception ex) { _status = $"Erro ao anexar {fileName}: {ex.Message}"; StateHasChanged(); }
    }

    private async Task LoadAttachments()
    {
        if (_selectedNote is null) { _attachments.Clear(); return; }
        try
        {
            var all = await Api.GetAttachmentsAsync(_selectedNote.Id);
            _attachments = all.Where(a => !a.IsEmbedded).ToList();
        }
        catch { _attachments.Clear(); }
    }

    private async Task AttachFiles(InputFileChangeEventArgs e)
    {
        if (_selectedNote is null) return;
        foreach (var file in e.GetMultipleFiles(20))
        {
            try
            {
                var existing = _attachments.FirstOrDefault(a =>
                    string.Equals(a.FileName, file.Name, StringComparison.OrdinalIgnoreCase));
                if (existing is not null)
                {
                    if (!await Confirm($"Já existe um anexo chamado \"{file.Name}\". Deseja substituir?"))
                        continue;
                    try { await Api.DeleteAttachmentAsync(existing.Id); } catch { }
                    _attachments.Remove(existing);
                }
                await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
                var dto = await Api.UploadAttachmentAsync(_selectedNote.Id, file.Name, file.ContentType, stream);
                _attachments.Add(dto);
            }
            catch (Exception ex) { _status = $"Erro ao anexar {file.Name}: {ex.Message}"; }
        }
        StateHasChanged();
    }

    private async Task OpenAttachment(AttachmentDto att) =>
        await JS.InvokeVoidAsync("open", Api.GetAttachmentUrl(att.Id), "_blank");

    private void OpenAttachmentMenu(AttachmentDto att, MouseEventArgs e) =>
        _attCtx = new AttachmentCtxMenu(e.ClientX, e.ClientY, att);

    private void CloseAttachmentMenu() => _attCtx = null;

    private async Task InsertAttachmentLinkFromCtx()
    {
        if (_attCtx is null || _editor is null) return;
        var att = _attCtx.Attachment;
        CloseAttachmentMenu();
        await _editor.InsertAttachmentLinkAsync(Api.GetAttachmentDownloadUrl(att.Id), att.FileName);
    }

    private async Task RenameAttachment()
    {
        if (_attCtx is null) return;
        var att = _attCtx.Attachment;
        CloseAttachmentMenu();
        var newName = await Prompt("Novo nome do arquivo:", att.FileName);
        if (string.IsNullOrWhiteSpace(newName) || newName == att.FileName) return;
        try
        {
            var updated = await Api.RenameAttachmentAsync(att.Id, newName);
            var idx = _attachments.IndexOf(att);
            if (idx >= 0) _attachments[idx] = updated;
            StateHasChanged();
        }
        catch (Exception ex) { _status = $"Erro ao renomear anexo: {ex.Message}"; }
    }

    private async Task DeleteAttachmentFromCtx()
    {
        if (_attCtx is null) return;
        var att = _attCtx.Attachment;
        CloseAttachmentMenu();
        await DeleteAttachment(att);
    }

    private async Task DeleteAttachment(AttachmentDto att)
    {
        if (!await Confirm($"Excluir o anexo \"{att.FileName}\"?")) return;
        try
        {
            await Api.DeleteAttachmentAsync(att.Id);
            _attachments.Remove(att);
            StateHasChanged();
        }
        catch (Exception ex) { _status = $"Erro ao excluir anexo: {ex.Message}"; }
    }

    private static string FileIcon(string ct) => ct switch
    {
        _ when ct.StartsWith("image/") => "ti-photo",
        _ when ct.Contains("pdf") => "ti-file-type-pdf",
        _ when ct.Contains("word") || ct.Contains("document") => "ti-file-type-doc",
        _ when ct.Contains("sheet") || ct.Contains("excel") || ct.Contains("spreadsheet") => "ti-file-type-xls",
        _ when ct.Contains("zip") || ct.Contains("compressed") || ct.Contains("x-tar") => "ti-file-zip",
        _ when ct.Contains("text/") => "ti-file-text",
        _ => "ti-file",
    };

    // ---------- Backup export ----------

    private async Task ExportFolder(FolderDto folder)
    {
        CloseMenus();
        await RunExport(folder.Id, folder.Name);
    }

    private async Task ExportFullBackup()
    {
        CloseMenus();
        await RunExport(null, $"ultranote-backup-{DateTime.Now:yyyy-MM-dd}");
    }

    private async Task RunExport(Guid? rootFolderId, string fileNameBase)
    {
        if (_exporting || _downloadJs is null) return;
        _exporting = true;
        _status = "Exportando...";
        StateHasChanged();
        try
        {
            var bytes = await BackupExporter.ExportAsync(Api, _folders, rootFolderId);
            await _downloadJs.InvokeVoidAsync("downloadBytes", bytes, $"{fileNameBase}.zip", "application/zip");
            _status = "Exportação concluída.";
        }
        catch (Exception ex)
        {
            _status = $"Erro ao exportar: {ex.Message}";
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    // ---------- Evernote import ----------

    private void OpenImport() => _import = new ImportState();
    private void CloseImport() => _import = null;

    private async Task DoImport(InputFileChangeEventArgs e)
    {
        if (_import is null) return;
        if (!Guid.TryParse(_import.FolderIdStr, out var folderId))
        {
            _import.Status = "Selecione uma pasta de destino.";
            return;
        }

        // Read file BEFORE StateHasChanged — re-rendering invalidates the InputFile reference
        using var buf = new MemoryStream();
        try
        {
            await using var raw = e.File.OpenReadStream(maxAllowedSize: 200L * 1024 * 1024);
            await raw.CopyToAsync(buf);
        }
        catch (Exception ex)
        {
            _import.Status = $"Erro ao ler arquivo: {ex.Message}";
            return;
        }
        buf.Position = 0;

        _import.Importing = true;
        _import.Done = 0;
        _import.Failed = 0;
        _import.Status = "";
        StateHasChanged();

        try
        {
            var notes = EnexImporter.Parse(buf);

            _import.Total = notes.Count;
            StateHasChanged();

            await ImportNotesAsync(notes, folderId, _import);

            await LoadNotes(folderId);
            _import.Status = _import.Failed == 0
                ? $"{_import.Done} nota(s) importada(s) com sucesso."
                : $"{_import.Done} importada(s), {_import.Failed} falha(s).";
        }
        catch (Exception ex)
        {
            _import.Status = $"Erro ao ler arquivo: {ex.Message}";
        }

        _import.Importing = false;
        StateHasChanged();
    }

    // Creates each note, uploads its resources (images embedded, others as attachments), and
    // persists the converted HTML. Shared by the single-.enex import and the backup restore
    // flow — stripStyles=false for restore, since that content is UltraNote's own HTML (not
    // Evernote's), and stripping its style/class attributes would drop colors/highlights/
    // table sizing.
    private async Task ImportNotesAsync(List<EnexNote> notes, Guid folderId, ImportState state, bool stripStyles = true)
    {
        foreach (var note in notes)
        {
            try
            {
                var created = await Api.CreateNoteAsync(new CreateNoteRequest(folderId, note.Title, "<p></p>"));

                var hashToUrl = new Dictionary<string, string>();
                foreach (var res in note.Resources)
                {
                    try
                    {
                        using var ms = new MemoryStream(res.Data);
                        var dto = await Api.UploadAttachmentAsync(
                            created.Id, res.FileName, res.Mime, ms,
                            isEmbedded: res.Mime.StartsWith("image/"));
                        if (dto.Id == Guid.Empty)
                            throw new InvalidOperationException("resposta da API sem ID de anexo válido");
                        hashToUrl[res.Hash] = Api.GetAttachmentUrl(dto.Id);
                    }
                    catch (Exception ex)
                    {
                        state.Errors.Add($"{note.Title} — anexo \"{res.FileName}\": {ex.Message}");
                    }
                }

                var html = EnexImporter.ConvertEnml(note.RawEnml, hashToUrl, stripStyles);
                await Api.UpdateNoteAsync(created.Id, new UpdateNoteRequest(note.Title, html, null));

                state.Done++;
            }
            catch (Exception ex)
            {
                state.Failed++;
                state.Errors.Add($"{note.Title}: {ex.Message}");
            }
            StateHasChanged();
        }
    }

    // ---------- Backup restore ----------

    private void OpenRestore() => _restore = new RestoreState();
    private void CloseRestore() => _restore = null;

    private async Task DoRestore(InputFileChangeEventArgs e)
    {
        if (_restore is null) return;
        if (!Guid.TryParse(_restore.FolderIdStr, out var destFolderId))
        {
            _restore.Status = "Selecione uma pasta de destino.";
            return;
        }

        // Read file BEFORE StateHasChanged — re-rendering invalidates the InputFile reference
        using var buf = new MemoryStream();
        try
        {
            await using var raw = e.File.OpenReadStream(maxAllowedSize: 500L * 1024 * 1024);
            await raw.CopyToAsync(buf);
        }
        catch (Exception ex)
        {
            _restore.Status = $"Erro ao ler arquivo: {ex.Message}";
            return;
        }
        buf.Position = 0;

        _restore.Importing = true;
        _restore.DoneFolders = 0;
        _restore.Status = "";
        StateHasChanged();

        try
        {
            using var zip = new ZipArchive(buf, ZipArchiveMode.Read);
            const string marker = "_notes.enex";
            var entries = zip.Entries
                .Where(en => en.FullName.EndsWith(marker, StringComparison.OrdinalIgnoreCase))
                .OrderBy(en => en.FullName.Count(c => c == '/'))
                .ToList();

            _restore.TotalFolders = entries.Count;
            StateHasChanged();

            var folderIdByPath = new Dictionary<string, Guid>(StringComparer.Ordinal);
            var importState = new ImportState();

            foreach (var entry in entries)
            {
                var dirPath = entry.FullName[..^marker.Length].TrimEnd('/');
                var segments = dirPath.Split('/', StringSplitOptions.RemoveEmptyEntries);

                var parentId = destFolderId;
                var pathKey = "";
                foreach (var seg in segments)
                {
                    pathKey = pathKey.Length == 0 ? seg : $"{pathKey}/{seg}";
                    if (!folderIdByPath.TryGetValue(pathKey, out var fid))
                    {
                        var created = await Api.CreateFolderAsync(new CreateFolderRequest(parentId, seg));
                        fid = created.Id;
                        folderIdByPath[pathKey] = fid;
                    }
                    parentId = fid;
                }

                _restore.Status = $"Restaurando: {dirPath}";
                StateHasChanged();

                using var entryStream = entry.Open();
                using var entryBuf = new MemoryStream();
                await entryStream.CopyToAsync(entryBuf);
                entryBuf.Position = 0;
                var notes = EnexImporter.Parse(entryBuf);

                await ImportNotesAsync(notes, parentId, importState, stripStyles: false);

                _restore.DoneFolders++;
                _restore.DoneNotes = importState.Done;
                _restore.FailedNotes = importState.Failed;
                _restore.Errors = importState.Errors;
                StateHasChanged();
            }

            await LoadFolders();
            await LoadNotes(destFolderId);
            _restore.Status = _restore.FailedNotes == 0
                ? $"{_restore.DoneNotes} nota(s) restaurada(s) em {_restore.DoneFolders} pasta(s)."
                : $"{_restore.DoneNotes} restaurada(s), {_restore.FailedNotes} falha(s).";
        }
        catch (Exception ex)
        {
            _restore.Status = $"Erro ao restaurar: {ex.Message}";
        }

        _restore.Importing = false;
        StateHasChanged();
    }

    private async Task<string?> Prompt(string message, string? def = null) =>
        await JS.InvokeAsync<string?>("prompt", message, def ?? "");

    private async Task<bool> Confirm(string message) => await JS.InvokeAsync<bool>("confirm", message);

    public async ValueTask DisposeAsync()
    {
        if (_themeJs is not null)
        {
            try { await _themeJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        if (_unsavedJs is not null)
        {
            try { await _unsavedJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        if (_shortcutsJs is not null)
        {
            try { await _shortcutsJs.InvokeVoidAsync("dispose"); await _shortcutsJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        if (_dropZoneJs is not null)
        {
            try { if (_dropZoneInitialized) await _dropZoneJs.InvokeVoidAsync("dispose", _attBar); } catch (JSDisconnectedException) { }
            try { await _dropZoneJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        if (_sidebarResizeJs is not null)
        {
            try { await _sidebarResizeJs.InvokeVoidAsync("dispose", _resizeHandle); } catch (JSDisconnectedException) { }
            try { await _sidebarResizeJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        if (_downloadJs is not null)
        {
            try { await _downloadJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
        _shortcutsRef?.Dispose();
    }

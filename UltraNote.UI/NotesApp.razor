@inject IUltraNoteApi Api
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="app">
    <header class="topbar">
        <span class="brand">
            <svg class="brand-logo" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect class="bl-bg"   width="200" height="200" rx="38"/>
                <path class="bl-page" d="M50,36 L124,36 L150,62 L150,168 L50,168 Z"/>
                <path class="bl-fold" d="M124,36 L150,62 L124,62 Z"/>
                <rect class="bl-line" x="66" y="84"  width="60" height="7" rx="3.5"/>
                <rect class="bl-line" x="66" y="100" width="68" height="7" rx="3.5"/>
                <rect class="bl-line" x="66" y="116" width="52" height="7" rx="3.5"/>
                <rect class="bl-line" x="66" y="132" width="64" height="7" rx="3.5"/>
                <rect class="bl-line" x="66" y="148" width="44" height="7" rx="3.5"/>
                <path fill="#C89B3C" d="M150,100 C154,127 173,146 200,150 C173,154 154,173 150,200 C146,173 127,154 100,150 C127,146 146,127 150,100Z"/>
            </svg>
            UltraNote
        </span>

        <nav class="breadcrumb">
            @if (_selectedNote is not null)
            {
                @foreach (var seg in BreadcrumbFolders())
                {
                    <span>@seg</span>
                    <i class="ti ti-chevron-right" aria-hidden="true"></i>
                }
                <span class="crumb-current">@_selectedNote.Title</span>
            }
        </nav>

        <div class="topbar-right">
            <div class="search">
                <i class="ti ti-search" aria-hidden="true"></i>
                <input placeholder="Buscar notas…" value="@_query" @oninput="OnSearchInput" />
            </div>
            <button class="icon-btn" title="Tema" @onclick="ToggleTheme"><i class="ti @(_theme == "dark" ? "ti-sun" : "ti-moon")" aria-hidden="true"></i></button>
            <button class="icon-btn" title="Sobre" @onclick="() => _showAbout = true"><i class="ti ti-info-circle" aria-hidden="true"></i></button>
            @TopBarUser
        </div>
    </header>

    <div class="body" @ref="_bodyEl">
        <aside class="sidebar">
            <div class="sidebar-toolbar">
                <button class="icon-btn" title="Nova pasta" @onclick="ToolbarNewFolder"><i class="ti ti-folder-plus" aria-hidden="true"></i></button>
                <button class="icon-btn" title="Nova nota" @onclick="ToolbarNewNote" disabled="@(_selectedFolderId is null)"><i class="ti ti-file-plus" aria-hidden="true"></i></button>
                <button class="icon-btn danger" title="Excluir" @onclick="ToolbarDelete" disabled="@(!CanToolbarDelete)"><i class="ti ti-trash" aria-hidden="true"></i></button>
                <div class="toolbar-sep"></div>
                <button class="icon-btn" title="Recolher tudo" @onclick="CollapseAll"><i class="ti ti-chevrons-left" aria-hidden="true"></i></button>
                <button class="icon-btn" title="Expandir tudo" @onclick="ToolbarExpandAll"><i class="ti ti-chevrons-right" aria-hidden="true"></i></button>
                <div class="toolbar-sep"></div>
                @if (_favoritesVisible)
                {
                    <button class="icon-btn active" title="Ocultar favoritos" @onclick="ToggleFavoritesVisible">
                        <svg class="star-filled-svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.243 7.34l-6.38.925-.113.023a1 1 0 0 0-.44 1.684l4.622 4.499-1.09 6.355-.013.11a1 1 0 0 0 1.464.944l5.706-3 5.693 3 .1.046a1 1 0 0 0 1.352-1.1l-1.091-6.355 4.624-4.5.078-.085a1 1 0 0 0-.633-1.62l-6.38-.926-2.852-5.78a1 1 0 0 0-1.794 0l-2.853 5.78z"/></svg>
                    </button>
                }
                else
                {
                    <button class="icon-btn" title="Exibir favoritos" @onclick="ToggleFavoritesVisible">
                        <i class="ti ti-star" aria-hidden="true"></i>
                    </button>
                }
                @if (_showArchived)
                {
                    <button class="icon-btn active" title="Ocultar arquivadas" @onclick="ToggleShowArchived">
                        <i class="ti ti-archive" aria-hidden="true"></i>
                    </button>
                }
                else
                {
                    <button class="icon-btn" title="@($"Exibir arquivadas ({_archivedCount})")" @onclick="ToggleShowArchived">
                        <i class="ti ti-archive-off" aria-hidden="true"></i>
                    </button>
                }
                <button class="icon-btn push-right" title="Ferramentas" @onclick="OpenToolsMenu"><i class="ti ti-dots-vertical" aria-hidden="true"></i></button>
            </div>
            <div class="sidebar-content">
                @if (string.IsNullOrWhiteSpace(_query))
                {
                    @if (_favoritesVisible)
                    {
                        <div class="tree-row fav-root-row">
                            <svg class="star-filled-svg fav-ico" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.243 7.34l-6.38.925-.113.023a1 1 0 0 0-.44 1.684l4.622 4.499-1.09 6.355-.013.11a1 1 0 0 0 1.464.944l5.706-3 5.693 3 .1.046a1 1 0 0 0 1.352-1.1l-1.091-6.355 4.624-4.5.078-.085a1 1 0 0 0-.633-1.62l-6.38-.926-2.852-5.78a1 1 0 0 0-1.794 0l-2.853 5.78z"/></svg>
                            <span class="tree-label">Favoritos</span>
                            @if (VisibleFavorites.Count > 0) { <span class="fav-badge">@VisibleFavorites.Count</span> }
                        </div>
                        @if (VisibleFavorites.Count == 0)
                        {
                            <p class="empty fav-empty">Nenhum favorito ainda.</p>
                        }
                        else
                        {
                            @foreach (var fav in VisibleFavorites)
                            {
                                <div class="tree-note fav-note @(fav.Id == SelectedNoteId ? "active" : "") @(fav.IsArchived ? "archived-note" : "")"
                                     draggable="true"
                                     @ondragstart="() => StartDragNote(fav)"
                                     @onclick="() => RequestSelectNote(fav.Id)"
                                     @oncontextmenu:preventDefault="true"
                                     @oncontextmenu="(e) => OpenNoteMenu(fav, e)">
                                    <i class="ti ti-file-text note-ico" aria-hidden="true"></i>
                                    <span class="tree-label">@fav.Title</span>
                                    @if (fav.IsArchived) { <i class="ti ti-archive note-archive-ico" aria-hidden="true"></i> }
                                </div>
                            }
                        }
                        <div class="sidebar-sep"></div>
                    }
                    <div class="tree-row tree-root @(_selectedFolderId is null ? "active" : "") @(_dragOverRoot ? "drag-over" : "")"
                         @ondragover:preventDefault="true"
                         @ondragenter="() => _dragOverRoot = true"
                         @ondragleave="() => _dragOverRoot = false"
                         @ondrop="DropOnRoot"
                         @onclick="SelectRoot">
                        <i class="ti ti-notebook folder-ico" aria-hidden="true"></i>
                        <span class="tree-label">Notas</span>
                    </div>
                    <CascadingValue Value="this">
                        @foreach (var root in ChildrenOf(null))
                        {
                            <TreeNode Folder="root" Depth="0" />
                        }
                    </CascadingValue>
                    @if (_folders.Count == 0)
                    {
                        <p class="empty">Use a barra de ferramentas para criar sua primeira pasta.</p>
                    }
                }
                else
                {
                    @foreach (var n in _searchResults)
                    {
                        <div class="tree-note @(n.Id == SelectedNoteId ? "active" : "") @(n.IsArchived ? "archived-note" : "")"
                             @onclick="() => RequestSelectNote(n.Id)"
                             @oncontextmenu:preventDefault="true"
                             @oncontextmenu="(e) => OpenNoteMenu(n, e)">
                            <i class="ti ti-file-text note-ico" aria-hidden="true"></i>
                            <span class="tree-label">@n.Title</span>
                            @if (n.IsArchived) { <i class="ti ti-archive note-archive-ico" aria-hidden="true"></i> }
                            <span class="result-folder">@(FolderById(n.FolderId)?.Name)</span>
                        </div>
                    }
                    @if (_searchResults.Count == 0)
                    {
                        <p class="empty">Nada encontrado.</p>
                    }
                }
            </div>
        </aside>

        <div class="sidebar-resize-handle" @ref="_resizeHandle"></div>

        <section class="editor-panel">
            @if (_treeSelectionIsNote && _selectedNote is not null)
            {
                <div class="editor-head">
                    <input class="title-input" @bind="_title" @bind:event="oninput" />
                    @if (_selectedNote.IsFavorite)
                    {
                        <button class="icon-btn star-btn" title="Desfavoritar" @onclick="ToggleFavoriteCurrentNote">
                            <svg class="star-filled-svg" style="color:#C89B3C" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.243 7.34l-6.38.925-.113.023a1 1 0 0 0-.44 1.684l4.622 4.499-1.09 6.355-.013.11a1 1 0 0 0 1.464.944l5.706-3 5.693 3 .1.046a1 1 0 0 0 1.352-1.1l-1.091-6.355 4.624-4.5.078-.085a1 1 0 0 0-.633-1.62l-6.38-.926-2.852-5.78a1 1 0 0 0-1.794 0l-2.853 5.78z"/></svg>
                        </button>
                    }
                    else
                    {
                        <button class="icon-btn star-btn" title="Favoritar" @onclick="ToggleFavoriteCurrentNote">
                            <i class="ti ti-star" aria-hidden="true"></i>
                        </button>
                    }
                    <button class="icon-btn archive-btn @(_selectedNote.IsArchived ? "active" : "")" title="@(_selectedNote.IsArchived ? "Desarquivar" : "Arquivar")" @onclick="ToggleArchiveCurrentNote">
                        <i class="ti @(_selectedNote.IsArchived ? "ti-archive-off" : "ti-archive")" aria-hidden="true"></i>
                    </button>
                    <button class="btn-accent" @onclick="SaveNote" disabled="@_saving">@(_saving ? "Salvando…" : _dirty ? "Salvar *" : "Salvar")</button>
                </div>
                <div class="editor-meta">@_meta</div>
                <RichTextEditor @ref="_editor" Html="@_selectedNote.ContentHtml" OnChanged="MarkDirty" NoteId="@_selectedNote.Id" OnAttachmentAdded="LoadAttachments" ExistingAttachments="_attachments" />
                <div class="attachments-bar" @ref="_attBar">
                    <div class="attachments-header">
                        <i class="ti ti-paperclip" aria-hidden="true"></i>
                        <span>Anexos</span>
                        @if (_attachments.Count > 0)
                        {
                            <span class="attachments-count">@_attachments.Count</span>
                        }
                        <label class="icon-btn att-add-btn" title="Anexar arquivo">
                            <i class="ti ti-plus" aria-hidden="true"></i>
                            <InputFile style="display:none" OnChange="AttachFiles" multiple accept="*/*" />
                        </label>
                    </div>
                    @if (_attachments.Count > 0)
                    {
                        <div class="attachments-list">
                            @foreach (var att in _attachments)
                            {
                                <div class="attachment-item" @ondblclick="() => OpenAttachment(att)" @oncontextmenu:preventDefault="true" @oncontextmenu="(e) => OpenAttachmentMenu(att, e)">
                                    <i class="ti @FileIcon(att.ContentType)" aria-hidden="true"></i>
                                    <span class="att-name" title="@att.FileName">@att.FileName</span>
                                    <a class="icon-btn" href="@Api.GetAttachmentDownloadUrl(att.Id)" target="_blank" title="Baixar"><i class="ti ti-download" aria-hidden="true"></i></a>
                                    <button class="icon-btn danger" title="Excluir anexo" @onclick="() => DeleteAttachment(att)"><i class="ti ti-trash" aria-hidden="true"></i></button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty att-empty">Nenhum arquivo anexado.</p>
                    }
                </div>
            }
            else if (!_treeSelectionIsNote && _selectedFolderId is not null)
            {
                var folderNotes = NotesOf(_selectedFolderId.Value) ?? new List<NoteSummaryDto>();
                <div class="folder-view">
                    <div class="folder-view-header">
                        <i class="ti ti-folder" aria-hidden="true"></i>
                        <span>@(FolderById(_selectedFolderId.Value)?.Name ?? "")</span>
                        <span class="folder-view-count">@folderNotes.Count nota@(folderNotes.Count == 1 ? "" : "s")</span>
                    </div>
                    @if (folderNotes.Count > 0)
                    {
                        <div class="folder-view-list">
                            @foreach (var note in folderNotes)
                            {
                                <div class="folder-view-item" @onclick="() => RequestSelectNote(note.Id)">
                                    <i class="ti ti-file-text" aria-hidden="true"></i>
                                    <span>@note.Title</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty">Nenhuma nota nesta pasta.</p>
                    }
                </div>
            }
            else
            {
                <div class="editor-empty">Selecione uma pasta ou nota para começar.</div>
            }
            <footer class="statusbar">@_status</footer>
        </section>
    </div>

    @if (_ctx is not null)
    {
        <div class="menu-backdrop" @onclick="CloseMenus" @oncontextmenu:preventDefault="true" @oncontextmenu="CloseMenus"></div>
        <div class="menu" style="left:@($"{_ctx.X}px");top:@($"{_ctx.Y}px")">
            @if (_ctx.Kind == "new")
            {
                <button @onclick="() => GuardUnsaved(() => NewNote(_selectedFolderId))" disabled="@(_selectedFolderId is null)"><i class="ti ti-file-plus" aria-hidden="true"></i>Nova nota</button>
                <button @onclick="() => NewFolder(null)"><i class="ti ti-folder-plus" aria-hidden="true"></i>Nova pasta</button>
            }
            else if (_ctx.Kind == "folder")
            {
                <button @onclick="() => GuardUnsaved(() => NewNote(_ctx.Folder!.Id))"><i class="ti ti-file-plus" aria-hidden="true"></i>Nova nota</button>
                <button @onclick="() => NewFolder(_ctx.Folder!.Id)"><i class="ti ti-folder-plus" aria-hidden="true"></i>Nova subpasta</button>
                <hr />
                <button @onclick="() => RenameFolder(_ctx.Folder!)"><i class="ti ti-pencil" aria-hidden="true"></i>Renomear</button>
                <button @onclick="() => OpenMoveFolder(_ctx.Folder!)"><i class="ti ti-folder-symlink" aria-hidden="true"></i>Mover...</button>
                <button @onclick="() => ExportFolder(_ctx.Folder!)" disabled="@_exporting"><i class="ti ti-file-zip" aria-hidden="true"></i>Exportar pasta (.zip)</button>
                <button class="danger" @onclick="() => DeleteFolder(_ctx.Folder!)"><i class="ti ti-trash" aria-hidden="true"></i>Excluir</button>
            }
            else if (_ctx.Kind == "tools")
            {
                <button @onclick="() => { CloseMenus(); OpenImport(); }"><i class="ti ti-file-import" aria-hidden="true"></i>Importar do Evernote</button>
                <hr />
                <button @onclick="ExportFullBackup" disabled="@_exporting"><i class="ti ti-file-zip" aria-hidden="true"></i>Exportar backup completo (.zip)</button>
                <button @onclick="() => { CloseMenus(); OpenRestore(); }"><i class="ti ti-database-import" aria-hidden="true"></i>Importar backup (.zip)</button>
            }
            else
            {
                <button @onclick="() => ToggleFavorite(_ctx.Note!)">
                    <i class="ti @(_ctx.Note!.IsFavorite ? "ti-star-off" : "ti-star")" aria-hidden="true"></i>
                    @(_ctx.Note!.IsFavorite ? "Desfavoritar" : "Favoritar")
                </button>
                <button @onclick="() => ToggleArchive(_ctx.Note!)">
                    <i class="ti @(_ctx.Note!.IsArchived ? "ti-archive-off" : "ti-archive")" aria-hidden="true"></i>
                    @(_ctx.Note!.IsArchived ? "Desarquivar" : "Arquivar")
                </button>
                <hr />
                <button @onclick="() => RenameNote(_ctx.Note!)"><i class="ti ti-pencil" aria-hidden="true"></i>Renomear</button>
                <button @onclick="() => OpenMoveNote(_ctx.Note!)"><i class="ti ti-folder-symlink" aria-hidden="true"></i>Mover...</button>
                <button class="danger" @onclick="() => DeleteNote(_ctx.Note!)"><i class="ti ti-trash" aria-hidden="true"></i>Excluir</button>
            }
        </div>
    }

    @if (_attCtx is not null)
    {
        <div class="menu-backdrop" @onclick="CloseAttachmentMenu" @oncontextmenu:preventDefault="true" @oncontextmenu="CloseAttachmentMenu"></div>
        <div class="menu" style="left:@($"{_attCtx.X}px");top:@($"{_attCtx.Y}px")">
            <button @onclick="InsertAttachmentLinkFromCtx"><i class="ti ti-link" aria-hidden="true"></i>Inserir link no texto</button>
            <button @onclick="RenameAttachment"><i class="ti ti-pencil" aria-hidden="true"></i>Renomear</button>
            <button class="danger" @onclick="DeleteAttachmentFromCtx"><i class="ti ti-trash" aria-hidden="true"></i>Excluir</button>
        </div>
    }

    @if (_import is not null)
    {
        <div class="modal-backdrop">
            <div class="modal-card">
                <h2>Importar do Evernote</h2>
                @if (_import.Importing)
                {
                    <p>Importando nota @_import.Done de @_import.Total&hellip;</p>
                    <div class="import-bar"><div class="import-fill" style="width:@(_import.Total > 0 ? (_import.Done * 100 / _import.Total) : 0)%"></div></div>
                }
                else
                {
                    <p>Selecione um arquivo <strong>.enex</strong> exportado pelo Evernote e a pasta destino.</p>
                    <select class="modal-select" @bind="_import.FolderIdStr">
                        <option value="">— pasta destino —</option>
                        @foreach (var f in _folders.OrderBy(f => f.Path))
                        {
                            <option value="@f.Id">@f.Path</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(_import.Status))
                    {
                        <p class="import-status">@_import.Status</p>
                    }
                    @if (_import.Errors.Count > 0)
                    {
                        <ul class="import-errors">
                            @foreach (var err in _import.Errors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    }
                }
                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="CloseImport" disabled="@_import.Importing">Cancelar</button>
                    @if (!_import.Importing)
                    {
                        <label class="btn-accent" style="cursor:pointer">
                            Escolher arquivo
                            <InputFile style="display:none" OnChange="DoImport" accept=".enex" />
                        </label>
                    }
                </div>
            </div>
        </div>
    }

    @if (_restore is not null)
    {
        <div class="modal-backdrop">
            <div class="modal-card">
                <h2>Importar backup</h2>
                @if (_restore.Importing)
                {
                    <p>Restaurando pasta @_restore.DoneFolders de @_restore.TotalFolders&hellip;</p>
                    <div class="import-bar"><div class="import-fill" style="width:@(_restore.TotalFolders > 0 ? (_restore.DoneFolders * 100 / _restore.TotalFolders) : 0)%"></div></div>
                    @if (!string.IsNullOrEmpty(_restore.Status))
                    {
                        <p class="import-status">@_restore.Status</p>
                    }
                }
                else
                {
                    <p>Selecione um arquivo <strong>.zip</strong> gerado pelo "Exportar backup" e a pasta destino (as pastas do backup serão recriadas dentro dela).</p>
                    <select class="modal-select" @bind="_restore.FolderIdStr">
                        <option value="">— pasta destino —</option>
                        @foreach (var f in _folders.OrderBy(f => f.Path))
                        {
                            <option value="@f.Id">@f.Path</option>
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(_restore.Status))
                    {
                        <p class="import-status">@_restore.Status</p>
                    }
                    @if (_restore.Errors.Count > 0)
                    {
                        <ul class="import-errors">
                            @foreach (var err in _restore.Errors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    }
                }
                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="CloseRestore" disabled="@_restore.Importing">Cancelar</button>
                    @if (!_restore.Importing)
                    {
                        <label class="btn-accent" style="cursor:pointer">
                            Escolher arquivo
                            <InputFile style="display:none" OnChange="DoRestore" accept=".zip" />
                        </label>
                    }
                </div>
            </div>
        </div>
    }

    @if (_showAbout)
    {
        <div class="modal-backdrop" @onclick="() => _showAbout = false">
            <div class="modal-card about-card" @onclick:stopPropagation="true">
                <div class="about-logo">
                    <svg width="72" height="72" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="50" cy="50" r="50" fill="#0F2535" />
                        <path fill="#C89B3C" d="M50,22 C52.5,37 63,48 78,50 C63,52 52.5,63 50,78 C47.5,63 37,52 22,50 C37,48 47.5,37 50,22Z" />
                    </svg>
                    <span class="about-brand">U L T R A S O F T</span>
                </div>

                <h2 class="about-appname">UltraNote</h2>
                <p class="about-version">@AppVersion</p>
                <p class="about-stack">C# &middot; .NET 10 &middot; Blazor WASM &middot; ASP.NET Core</p>

                <hr class="about-sep" />

                <p class="about-devby">Desenvolvido por</p>
                <p class="about-dev"><strong>Marcus Siqueira</strong></p>
                <p class="about-dev">ChatGPT <em>&ldquo;Raj&rdquo;</em> Codex</p>
                <p class="about-dev">Claude <em>&ldquo;Claudinho&rdquo;</em> Code</p>

                <hr class="about-sep" />

                <a class="about-link" href="https://github.com/mvsiqueira/UltraNote2" target="_blank" rel="noopener">
                    github.com/mvsiqueira/UltraNote2
                </a>
                <p class="about-copy">&copy; 2025&ndash;2026 Ultrasoft</p>

                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="() => _showAbout = false">Fechar</button>
                </div>
            </div>
        </div>
    }

    @if (_pendingAction is not null)
    {
        <div class="modal-backdrop">
            <div class="modal-card">
                <h2>Alterações não salvas</h2>
                <p>A nota atual tem alterações não salvas. Se continuar, elas serão descartadas.</p>
                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="CancelPendingAction">Cancelar</button>
                    <button class="btn-danger" @onclick="ConfirmPendingAction">Descartar e continuar</button>
                </div>
            </div>
        </div>
    }

    @if (_move is not null)
    {
        <div class="modal-backdrop">
            <div class="modal-card">
                <h2>Mover @(_move.Folder is not null ? "pasta" : "nota")</h2>
                <p>Escolha o destino de "@(_move.Folder?.Name ?? _move.Note?.Title)".</p>
                <select class="modal-select" @bind="_moveDestinationValue">
                    @if (_move.Folder is not null)
                    {
                        <option value="@RootSentinel">(raiz)</option>
                    }
                    @foreach (var f in MoveDestinationCandidates())
                    {
                        <option value="@f.Id">@f.Path</option>
                    }
                </select>
                <div class="modal-actions">
                    <button class="btn-ghost" @onclick="CancelMove">Cancelar</button>
                    <button class="btn-accent" @onclick="ConfirmMove">Mover</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? TopBarUser { get; set; }

    private record CtxMenu(double X, double Y, string Kind, FolderDto? Folder, NoteSummaryDto? Note);
    private bool _showAbout;
    private static string AppVersion
    {
        get
        {
            return "v2.0.0";
        }
    }

    private sealed class ImportState { public string FolderIdStr = ""; public bool Importing; public int Total, Done, Failed; public string Status = ""; public List<string> Errors = new(); }
    private ImportState? _import;
    private sealed class RestoreState { public string FolderIdStr = ""; public bool Importing; public int TotalFolders, DoneFolders, DoneNotes, FailedNotes; public string Status = ""; public List<string> Errors = new(); }
    private RestoreState? _restore;
    private bool _exporting;
    private IJSObjectReference? _downloadJs;
    private record AttachmentCtxMenu(double X, double Y, AttachmentDto Attachment);
    private AttachmentCtxMenu? _attCtx;

    private List<FolderDto> _folders = new();

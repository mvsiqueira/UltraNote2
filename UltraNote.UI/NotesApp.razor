@inject IUltraNoteApi Api
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="app">
    <header class="topbar">
        <span class="brand"><i class="ti ti-notebook" aria-hidden="true"></i>UltraNote</span>

        <nav class="breadcrumb">
            @if (_selectedNote is not null)
            {
                @foreach (var seg in BreadcrumbFolders())
                {
                    <span>@seg</span>
                    <i class="ti ti-chevron-right" aria-hidden="true"></i>
                }
                <span class="crumb-current">@_selectedNote.Title</span>
            }
        </nav>

        <div class="topbar-right">
            <div class="search">
                <i class="ti ti-search" aria-hidden="true"></i>
                <input placeholder="Buscar notas…" value="@_query" @oninput="OnSearchInput" />
            </div>
            <button class="icon-btn" title="Novo" @onclick="OpenNewMenu"><i class="ti ti-plus" aria-hidden="true"></i></button>
            <button class="icon-btn" title="Tema" @onclick="ToggleTheme"><i class="ti @(_theme == "dark" ? "ti-sun" : "ti-moon")" aria-hidden="true"></i></button>
            @TopBarUser
        </div>
    </header>

    <div class="body">
        <aside class="sidebar">
            @if (string.IsNullOrWhiteSpace(_query))
            {
                <CascadingValue Value="this">
                    @foreach (var root in ChildrenOf(null))
                    {
                        <TreeNode Folder="root" Depth="0" />
                    }
                </CascadingValue>
                @if (_folders.Count == 0)
                {
                    <p class="empty">Crie sua primeira pasta no botão “+”.</p>
                }
            }
            else
            {
                @foreach (var n in _searchResults)
                {
                    <div class="tree-note @(n.Id == SelectedNoteId ? "active" : "")"
                         @onclick="() => SelectNote(n.Id)"
                         @oncontextmenu:preventDefault="true"
                         @oncontextmenu="(e) => OpenNoteMenu(n, e)">
                        <i class="ti ti-file-text note-ico" aria-hidden="true"></i>
                        <span class="tree-label">@n.Title</span>
                        <span class="result-folder">@(FolderById(n.FolderId)?.Name)</span>
                    </div>
                }
                @if (_searchResults.Count == 0)
                {
                    <p class="empty">Nada encontrado.</p>
                }
            }
        </aside>

        <section class="editor-panel">
            @if (_selectedNote is not null)
            {
                <div class="editor-head">
                    <input class="title-input" @bind="_title" @bind:event="oninput" />
                    <button class="btn-accent" @onclick="SaveNote">@(_dirty ? "Salvar *" : "Salvar")</button>
                </div>
                <div class="editor-meta">@_meta</div>
                <RichTextEditor @ref="_editor" Html="@_selectedNote.ContentHtml" OnChanged="MarkDirty" />
            }
            else
            {
                <div class="editor-empty">Selecione ou crie uma nota para começar.</div>
            }
            <footer class="statusbar">@_status</footer>
        </section>
    </div>

    @if (_ctx is not null)
    {
        <div class="menu-backdrop" @onclick="CloseMenus" @oncontextmenu:preventDefault="true" @oncontextmenu="CloseMenus"></div>
        <div class="menu" style="left:@($"{_ctx.X}px");top:@($"{_ctx.Y}px")">
            @if (_ctx.Kind == "new")
            {
                <button @onclick="() => NewNote(_selectedFolderId)" disabled="@(_selectedFolderId is null)"><i class="ti ti-file-plus" aria-hidden="true"></i>Nova nota</button>
                <button @onclick="() => NewFolder(null)"><i class="ti ti-folder-plus" aria-hidden="true"></i>Nova pasta</button>
            }
            else if (_ctx.Kind == "folder")
            {
                <button @onclick="() => NewNote(_ctx.Folder!.Id)"><i class="ti ti-file-plus" aria-hidden="true"></i>Nova nota</button>
                <button @onclick="() => NewFolder(_ctx.Folder!.Id)"><i class="ti ti-folder-plus" aria-hidden="true"></i>Nova subpasta</button>
                <hr />
                <button @onclick="() => RenameFolder(_ctx.Folder!)"><i class="ti ti-pencil" aria-hidden="true"></i>Renomear</button>
                <button class="danger" @onclick="() => DeleteFolder(_ctx.Folder!)"><i class="ti ti-trash" aria-hidden="true"></i>Excluir</button>
            }
            else
            {
                <button @onclick="() => RenameNote(_ctx.Note!)"><i class="ti ti-pencil" aria-hidden="true"></i>Renomear</button>
                <button class="danger" @onclick="() => DeleteNote(_ctx.Note!)"><i class="ti ti-trash" aria-hidden="true"></i>Excluir</button>
            }
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? TopBarUser { get; set; }

    private record CtxMenu(double X, double Y, string Kind, FolderDto? Folder, NoteSummaryDto? Note);

    private List<FolderDto> _folders = new();
    private ILookup<Guid?, FolderDto> _byParent = Enumerable.Empty<FolderDto>().ToLookup(f => (Guid?)null);
    private readonly HashSet<Guid> _expanded = new();
    private readonly Dictionary<Guid, List<NoteSummaryDto>> _notes = new();

    private Guid? _selectedFolderId;
    private NoteDto? _selectedNote;
    private RichTextEditor? _editor;
    private string _title = "";
    private string _meta = "";
    private bool _dirty;
    private string _status = "Pronto.";

    private string _query = "";
    private List<NoteSummaryDto> _searchResults = new();

    private CtxMenu? _ctx;

    private string _theme = "light";
    private IJSObjectReference? _themeJs;

    public Guid? SelectedNoteId => _selectedNote?.Id;

    protected override async Task OnInitializedAsync() => await LoadFolders();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _themeJs = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/UltraNote.UI/ultranote-theme.js");
        _theme = await _themeJs.InvokeAsync<string>("getTheme");
        StateHasChanged();
    }

    // ---------- Tree data (used by TreeNode) ----------
    public IEnumerable<FolderDto> ChildrenOf(Guid? parentId) => _byParent[parentId];
    public bool IsExpanded(Guid id) => _expanded.Contains(id);
    public List<NoteSummaryDto>? NotesOf(Guid id) => _notes.TryGetValue(id, out var l) ? l : null;

    public async Task ToggleFolder(FolderDto folder)
    {
        _selectedFolderId = folder.Id;
        if (!_expanded.Add(folder.Id)) { _expanded.Remove(folder.Id); StateHasChanged(); return; }
        if (!_notes.ContainsKey(folder.Id)) await LoadNotes(folder.Id);
        StateHasChanged();
    }

    // ---------- Loading ----------
    private async Task LoadFolders()
    {
        try
        {
            _folders = (await Api.GetFoldersAsync()).ToList();
            _byParent = _folders.ToLookup(f => f.ParentId);
        }
        catch (Exception ex) { _status = $"Erro ao carregar pastas: {ex.Message}"; }
    }

    private async Task LoadNotes(Guid folderId)
    {
        try { _notes[folderId] = (await Api.GetNotesAsync(folderId)).ToList(); }
        catch (Exception ex) { _status = $"Erro ao carregar notas: {ex.Message}"; }
    }

    // ---------- Selection ----------
    public async Task SelectNote(Guid id)
    {
        try
        {
            _selectedNote = await Api.GetNoteAsync(id);
            if (_selectedNote is not null)
            {
                _selectedFolderId = _selectedNote.FolderId;
                _title = _selectedNote.Title;
                _dirty = false;
                UpdateMeta();
                _status = $"Editando: {_selectedNote.Title}";
            }
            else { _status = "Nota não encontrada."; }
        }
        catch (Exception ex) { _status = $"Erro ao abrir nota: {ex.Message}"; }
        StateHasChanged();
    }

    private void MarkDirty() { if (!_dirty) { _dirty = true; StateHasChanged(); } }

    private async Task SaveNote()
    {
        if (_selectedNote is null || _editor is null) return;
        try
        {
            var html = await _editor.GetHtmlAsync();
            var updated = await Api.UpdateNoteAsync(_selectedNote.Id, new UpdateNoteRequest(_title, html, null));
            _selectedNote = updated;
            _dirty = false;
            UpdateMeta();
            if (_notes.ContainsKey(updated.FolderId)) await LoadNotes(updated.FolderId);
            _status = $"Salvo: {updated.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao salvar: {ex.Message}"; }
    }

    // ---------- Menus ----------
    private void OpenNewMenu(MouseEventArgs e) => _ctx = new CtxMenu(e.ClientX - 150, e.ClientY + 14, "new", null, null);
    public void OpenFolderMenu(FolderDto f, MouseEventArgs e) { _selectedFolderId = f.Id; _ctx = new CtxMenu(e.ClientX, e.ClientY, "folder", f, null); StateHasChanged(); }
    public void OpenNoteMenu(NoteSummaryDto n, MouseEventArgs e) { _ctx = new CtxMenu(e.ClientX, e.ClientY, "note", null, n); StateHasChanged(); }
    private void CloseMenus() => _ctx = null;

    // ---------- Actions ----------
    private async Task NewFolder(Guid? parentId)
    {
        CloseMenus();
        var name = await Prompt("Nome da pasta:");
        if (string.IsNullOrWhiteSpace(name)) return;
        try
        {
            var created = await Api.CreateFolderAsync(new CreateFolderRequest(parentId, name));
            await LoadFolders();
            if (parentId is { } p) _expanded.Add(p);
            _status = $"Pasta criada: {created.Name}";
        }
        catch (Exception ex) { _status = $"Erro ao criar pasta: {ex.Message}"; }
    }

    private async Task NewNote(Guid? folderId)
    {
        CloseMenus();
        if (folderId is not { } fid) { _status = "Selecione uma pasta primeiro."; return; }
        var title = await Prompt("Título da nota:");
        if (string.IsNullOrWhiteSpace(title)) return;
        try
        {
            var note = await Api.CreateNoteAsync(new CreateNoteRequest(fid, title, "<p></p>"));
            _expanded.Add(fid);
            await LoadNotes(fid);
            await SelectNote(note.Id);
            _status = $"Nota criada: {note.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao criar nota: {ex.Message}"; }
    }

    private async Task RenameFolder(FolderDto folder)
    {
        CloseMenus();
        var name = await Prompt("Novo nome da pasta:", folder.Name);
        if (string.IsNullOrWhiteSpace(name) || name == folder.Name) return;
        try
        {
            await Api.UpdateFolderAsync(folder.Id, new UpdateFolderRequest(name, null));
            await LoadFolders();
            _status = $"Pasta renomeada: {name}";
        }
        catch (Exception ex) { _status = $"Erro ao renomear: {ex.Message}"; }
    }

    private async Task DeleteFolder(FolderDto folder)
    {
        CloseMenus();
        if (!await Confirm($"Excluir a pasta \"{folder.Name}\" e todo o conteúdo?")) return;
        try
        {
            await Api.DeleteFolderAsync(folder.Id);
            _notes.Remove(folder.Id);
            _expanded.Remove(folder.Id);
            if (_selectedNote is not null && IsUnder(_selectedNote.FolderId, folder)) ClearEditor();
            await LoadFolders();
            _status = $"Pasta excluída: {folder.Name}";
        }
        catch (Exception ex) { _status = $"Erro ao excluir: {ex.Message}"; }
    }

    private async Task RenameNote(NoteSummaryDto note)
    {
        CloseMenus();
        var title = await Prompt("Novo título da nota:", note.Title);
        if (string.IsNullOrWhiteSpace(title) || title == note.Title) return;
        try
        {
            await Api.UpdateNoteAsync(note.Id, new UpdateNoteRequest(title, null, null));
            if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
            if (_selectedNote?.Id == note.Id) { _selectedNote = await Api.GetNoteAsync(note.Id); _title = _selectedNote?.Title ?? _title; }
            if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
            _status = $"Nota renomeada: {title}";
        }
        catch (Exception ex) { _status = $"Erro ao renomear: {ex.Message}"; }
    }

    private async Task DeleteNote(NoteSummaryDto note)
    {
        CloseMenus();
        if (!await Confirm($"Excluir a nota \"{note.Title}\"?")) return;
        try
        {
            await Api.DeleteNoteAsync(note.Id);
            if (_notes.ContainsKey(note.FolderId)) await LoadNotes(note.FolderId);
            if (_selectedNote?.Id == note.Id) ClearEditor();
            if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
            _status = $"Nota excluída: {note.Title}";
        }
        catch (Exception ex) { _status = $"Erro ao excluir: {ex.Message}"; }
    }

    // ---------- Search ----------
    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        if (!string.IsNullOrWhiteSpace(_query)) await RunSearch();
    }

    private async Task RunSearch()
    {
        foreach (var f in _folders)
            if (!_notes.ContainsKey(f.Id)) await LoadNotes(f.Id);

        var q = _query.Trim();
        _searchResults = _notes.Values.SelectMany(x => x)
            .Where(n => n.Title.Contains(q, StringComparison.OrdinalIgnoreCase))
            .OrderBy(n => n.Title)
            .ToList();
    }

    // ---------- Theme ----------
    private async Task ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        if (_themeJs is not null) await _themeJs.InvokeVoidAsync("setTheme", _theme);
    }

    // ---------- Helpers ----------
    private FolderDto? FolderById(Guid id) => _folders.FirstOrDefault(f => f.Id == id);

    private IEnumerable<string> BreadcrumbFolders()
    {
        if (_selectedNote is null) return Enumerable.Empty<string>();
        var path = FolderById(_selectedNote.FolderId)?.Path;
        return string.IsNullOrEmpty(path) ? Enumerable.Empty<string>() : path.Split('/');
    }

    private bool IsUnder(Guid noteFolderId, FolderDto folder)
    {
        var nf = FolderById(noteFolderId);
        if (nf is null) return false;
        return nf.Id == folder.Id || nf.Path == folder.Path || nf.Path.StartsWith(folder.Path + "/");
    }

    private void ClearEditor() { _selectedNote = null; _title = ""; _meta = ""; _dirty = false; }

    private void UpdateMeta()
    {
        if (_selectedNote is null) { _meta = ""; return; }
        var words = WordCount(_selectedNote.ContentHtml);
        _meta = $"editada {_selectedNote.UpdatedAt.ToLocalTime():g} · {words} palavra{(words == 1 ? "" : "s")}";
    }

    private static int WordCount(string html)
    {
        var text = System.Text.RegularExpressions.Regex.Replace(html ?? "", "<[^>]+>", " ");
        text = System.Net.WebUtility.HtmlDecode(text);
        return text.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries).Length;
    }

    private async Task<string?> Prompt(string message, string? def = null) =>
        await JS.InvokeAsync<string?>("prompt", message, def ?? "");

    private async Task<bool> Confirm(string message) => await JS.InvokeAsync<bool>("confirm", message);

    public async ValueTask DisposeAsync()
    {
        if (_themeJs is not null)
        {
            try { await _themeJs.DisposeAsync(); } catch (JSDisconnectedException) { }
        }
    }
}

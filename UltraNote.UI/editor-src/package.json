{
  "name": "ultranote-editor",
  "private": true,
  "version": "1.0.0",
  "description": "TipTap rich-text editor bundle for UltraNote.UI. Source lives here; the built output is committed to wwwroot/ultranote-editor.js because the QNAP deploy environment does not run npm.",
  "type": "module",
  "scripts": {
    "build": "esbuild main.js --bundle --minify --format=esm --outfile=../wwwroot/ultranote-editor.js",
    "watch": "esbuild main.js --bundle --format=esm --outfile=../wwwroot/ultranote-editor.js --watch"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-color": "^2.11.0",
    "@tiptap/extension-highlight": "^2.11.0",
    "@tiptap/extension-link": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/extension-table": "^2.11.0",
    "@tiptap/extension-table-cell": "^2.11.0",
    "@tiptap/extension-table-header": "^2.11.0",
    "@tiptap/extension-table-row": "^2.11.0",
    "@tiptap/extension-text-style": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}

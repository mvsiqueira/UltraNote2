@* Recursive tree node: a folder row, then (when expanded) its subfolders and its notes. *@

<div class="tree-row @(Owner.SelectedFolderId == Folder.Id && !Owner.TreeSelectionIsNote ? "active" : "")" style="padding-left:@(8 + Depth * 15)px"
     @onclick="() => Owner.SelectFolder(Folder)"
     @oncontextmenu:preventDefault="true"
     @oncontextmenu="(e) => Owner.OpenFolderMenu(Folder, e)">
    <i class="ti @(Owner.IsExpanded(Folder.Id) ? "ti-chevron-down" : "ti-chevron-right") chevron" aria-hidden="true"
       @onclick:stopPropagation="true" @onclick="() => Owner.ToggleExpand(Folder)"></i>
    <i class="ti ti-folder folder-ico" aria-hidden="true"></i>
    <span class="tree-label">@Folder.Name</span>
</div>

@if (Owner.IsExpanded(Folder.Id))
{
    @foreach (var child in Owner.ChildrenOf(Folder.Id))
    {
        <TreeNode Folder="child" Depth="Depth + 1" />
    }

    @if (Owner.NotesOf(Folder.Id) is { } notes)
    {
        @* Notes have no chevron, so +20 (chevron width 14px + row gap 6px) keeps their
           icon aligned with where a child folder's icon would sit at the same depth. *@
        @foreach (var note in notes)
        {
            <div class="tree-note @(note.Id == Owner.SelectedNoteId ? "active" : "")"
                 style="padding-left:@(8 + (Depth + 1) * 15 + 20)px"
                 @onclick="() => Owner.RequestSelectNote(note.Id)"
                 @oncontextmenu:preventDefault="true"
                 @oncontextmenu="(e) => Owner.OpenNoteMenu(note, e)">
                <i class="ti ti-file-text note-ico" aria-hidden="true"></i>
                <span class="tree-label">@note.Title</span>
                @if (note.IsFavorite) { <i class="ti ti-star-filled note-fav-star" aria-hidden="true"></i> }
            </div>
        }
    }
}

@code {
    [CascadingParameter] public NotesApp Owner { get; set; } = default!;
    [Parameter] public FolderDto Folder { get; set; } = default!;
    [Parameter] public int Depth { get; set; }
}

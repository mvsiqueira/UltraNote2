# ---- build (publishes the Blazor WASM app to static files) ----
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# csproj first for restore-layer caching (Web -> UI -> Client -> Core).
COPY UltraNote.Core/UltraNote.Core.csproj UltraNote.Core/
COPY UltraNote.Client/UltraNote.Client.csproj UltraNote.Client/
COPY UltraNote.UI/UltraNote.UI.csproj UltraNote.UI/
COPY UltraNote.Web/UltraNote.Web.csproj UltraNote.Web/
RUN dotnet restore UltraNote.Web/UltraNote.Web.csproj

COPY UltraNote.Core/ UltraNote.Core/
COPY UltraNote.Client/ UltraNote.Client/
COPY UltraNote.UI/ UltraNote.UI/
COPY UltraNote.Web/ UltraNote.Web/
RUN dotnet publish UltraNote.Web/UltraNote.Web.csproj -c Release -o /app

# ---- runtime (nginx serving the static files) ----
FROM nginx:alpine AS runtime
COPY UltraNote.Web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/wwwroot /usr/share/nginx/html
EXPOSE 8080

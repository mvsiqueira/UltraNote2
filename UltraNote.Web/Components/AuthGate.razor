@using UltraNote.Web.Auth
@implements IDisposable
@inject GoogleAuthService Auth

@if (Auth.IsAuthenticated)
{
    @ChildContent
}
else
{
    <div class="login-screen">
        <div class="login-card">
            <i class="ti ti-notebook" aria-hidden="true"></i>
            <h1>UltraNote</h1>
            @if (Auth.AccessDenied)
            {
                <p class="login-denied">
                    A conta <strong>@Auth.DeniedEmail</strong> não tem acesso a este app.
                    Entre com outra conta autorizada.
                </p>
            }
            else
            {
                <p>Entre com sua conta Google para acessar suas notas.</p>
            }
            <div id="google-signin-button"></div>
        </div>
    </div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized() => Auth.OnChange += OnAuthChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Auth.IsEnabled) return;

        await Auth.InitAsync();                                  // restore cached token (no UI)
        if (!Auth.IsAuthenticated)
            await Auth.RenderButtonAndSilentAsync("google-signin-button");
    }

    private void OnAuthChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Auth.OnChange -= OnAuthChanged;
}
